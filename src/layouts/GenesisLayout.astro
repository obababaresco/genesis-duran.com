    <Analytics />
    <SpeedInsights />
    <script>
      // Toggle menu móvil y detección de sección activa
      document.addEventListener('DOMContentLoaded', () => {
        const toggle = document.querySelector('.navbar-toggle') as HTMLButtonElement;
        const menu = document.querySelector('.navbar-menu') as HTMLElement;
        
        if (toggle && menu) {
          toggle.addEventListener('click', () => {
            const isExpanded = toggle.getAttribute('aria-expanded') === 'true';
            toggle.setAttribute('aria-expanded', String(!isExpanded));
            menu.setAttribute('data-visible', String(!isExpanded));
          });

          // Cerrar menú al hacer clic en un enlace
          const navLinks = menu.querySelectorAll('.nav-link');
          navLinks.forEach(link => {
            link.addEventListener('click', () => {
              toggle.setAttribute('aria-expanded', 'false');
              menu.setAttribute('data-visible', 'false');
            });
          });

          // Cerrar menú al hacer clic fuera
          document.addEventListener('click', (e) => {
            if (!menu.contains(e.target as Node) && !toggle.contains(e.target as Node)) {
              toggle.setAttribute('aria-expanded', 'false');
              menu.setAttribute('data-visible', 'false');
            }
          });
        }

        // Detectar sección activa
        const sections = document.querySelectorAll('section[id], header[id]');
        const navLinks = document.querySelectorAll('.nav-link');
        
        // Función para actualizar el enlace activo
        const updateActiveLink = (sectionId: string) => {
          navLinks.forEach(link => {
            link.classList.remove('active');
            const href = link.getAttribute('href');
            if (href === `#${sectionId}`) {
              link.classList.add('active');
            }
          });
        };

        // Función para determinar qué sección está activa basándose en la posición del scroll
        const getActiveSection = () => {
          const scrollOffset = 250; // Offset para considerar navbar y área de detección
          const scrollPosition = window.scrollY + scrollOffset;
          
          let activeSectionId = '';
          let closestDistance = Infinity;

          sections.forEach(section => {
            const element = section as HTMLElement;
            const rect = element.getBoundingClientRect();
            const sectionTop = window.scrollY + rect.top;
            const sectionBottom = sectionTop + rect.height;
            const sectionId = section.getAttribute('id');
            
            if (!sectionId) return;

            // Si el scroll está dentro del rango de la sección
            if (scrollPosition >= sectionTop && scrollPosition <= sectionBottom) {
              // Calcular qué tan cerca está el scroll del inicio de la sección
              const distance = Math.abs(scrollPosition - sectionTop);
              if (distance < closestDistance) {
                closestDistance = distance;
                activeSectionId = sectionId;
              }
            }
          });

          // Si estamos en la parte superior de la página, activar la primera sección
          if (window.scrollY < 100) {
            const firstSection = sections[0];
            if (firstSection) {
              const firstSectionId = firstSection.getAttribute('id');
              if (firstSectionId) {
                return firstSectionId;
              }
            }
          }

          // Si no encontramos una sección activa, buscar la más cercana
          if (!activeSectionId) {
            sections.forEach(section => {
              const element = section as HTMLElement;
              const rect = element.getBoundingClientRect();
              const sectionTop = window.scrollY + rect.top;
              const sectionId = section.getAttribute('id');
              
              if (!sectionId) return;

              // Si la sección está visible en el viewport
              if (rect.top < window.innerHeight && rect.bottom > 0) {
                const distance = Math.abs(scrollPosition - sectionTop);
                if (distance < closestDistance) {
                  closestDistance = distance;
                  activeSectionId = sectionId;
                }
              }
            });
          }

          return activeSectionId;
        };

        // Actualizar sección activa al hacer scroll
        let ticking = false;
        const updateActiveSection = () => {
          const activeSectionId = getActiveSection();
          if (activeSectionId) {
            updateActiveLink(activeSectionId);
          }
          ticking = false;
        };

        window.addEventListener('scroll', () => {
          if (!ticking) {
            window.requestAnimationFrame(updateActiveSection);
            ticking = true;
          }
        }, { passive: true });

        // Establecer sección activa inicial
        updateActiveSection();
      });
    </script>

