            'process.hover5': 'Answers aren\'t always immediate',
            'process.hover7': 'Not everything designed stays',
            'process.hover8': 'Simplifying is part of the job',
            // Recomendaciones
            'recommendations.title': 'Recommendations',
            // Modal
            'modal.reto': 'Challenge:',
            'modal.solucion': 'Solution:',
            'modal.visitsite': 'Visit Website',
          }
        };

        // Función para obtener el idioma por defecto basado en el navegador
        const getDefaultLang = (): string => {
          const stored = localStorage.getItem('portfolio-lang');
          if (stored && (stored === 'es' || stored === 'en')) return stored;
          
          const browserLang = navigator.language || (navigator as any).userLanguage || 'es';
          return browserLang.startsWith('en') ? 'en' : 'es';
        };

        let currentLang = getDefaultLang();

        // Función para obtener traducción
        const t = (key: string): string => {
          return translations[currentLang]?.[key] || translations['es']?.[key] || key;
        };

        // Función para aplicar traducciones a elementos con data-i18n
        const applyStaticTranslations = () => {
          const elements = document.querySelectorAll('[data-i18n]') as NodeListOf<HTMLElement>;
          elements.forEach(el => {
            const key = el.getAttribute('data-i18n');
            if (!key) return;
            const translation = t(key);
            if (el.getAttribute('data-i18n-html') === 'true') {
              el.innerHTML = translation;
            } else {
              el.textContent = translation;
            }
          });
        };

        // Función para aplicar datos del JSON traducido a los proyectos
        const applyProjectTranslations = () => {
          const dataScript = document.getElementById('genesis-proyectos-data');
          const dataScriptEn = document.getElementById('genesis-proyectos-data-en');
          if (!dataScript || !dataScriptEn) return;

          const proyectosEs = JSON.parse(dataScript.textContent || '[]');
          const proyectosEn = JSON.parse(dataScriptEn.textContent || '[]');
          const proyectos = currentLang === 'en' ? proyectosEn : proyectosEs;

          // Actualizar tarjetas de proyecto
          const projectCards = document.querySelectorAll('.project-card');
          projectCards.forEach((card, index) => {
            if (index >= proyectos.length) return;
            const p = proyectos[index];
            
            const titleEl = card.querySelector('.project-card-title');
            if (titleEl) titleEl.textContent = p.title;
            
            const tagsContainer = card.querySelector('.project-tags');
            if (tagsContainer && p.tags) {
              tagsContainer.innerHTML = p.tags.map((tag: string) => 
                `<span class="project-tag tag">${tag}</span>`
              ).join('');
            }
          });

          // Almacenar datos de proyectos traducidos para el modal
          (window as any).__translatedProjects = proyectos;
        };

        // Función para aplicar traducciones de bio
        const applyBioTranslation = () => {
          const bioDataScript = document.getElementById('genesis-bio-data-en');
          const bioDataScriptEs = document.getElementById('genesis-bio-data-es');
          if (!bioDataScript || !bioDataScriptEs) return;

          const bioEn = bioDataScript.textContent || '';
          const bioEs = bioDataScriptEs.textContent || '';
          const bio = currentLang === 'en' ? bioEn : bioEs;

          const heroSubtitle = document.querySelector('.hero-subtitle-genesis') as HTMLElement;
          if (heroSubtitle) {
            heroSubtitle.setAttribute('data-bio', bio);
            // Reemplazar contenido actual
            heroSubtitle.innerHTML = bio.replace(/\[BR\]/g, '<br />');
          }
        };

        // Función para aplicar traducciones de recomendaciones
        const applyRecommendationTranslations = () => {
          const recDataEs = document.getElementById('genesis-recs-data-es');
          const recDataEn = document.getElementById('genesis-recs-data-en');
          if (!recDataEs || !recDataEn) return;

          const recsEs = JSON.parse(recDataEs.textContent || '[]');
          const recsEn = JSON.parse(recDataEn.textContent || '[]');
          const recs = currentLang === 'en' ? recsEn : recsEs;

          const recCards = document.querySelectorAll('.recommendation-card');
          recCards.forEach((card, index) => {
            if (index >= recs.length) return;
            const rec = recs[index];

            const authorEl = card.querySelector('.recommendation-author');
            if (authorEl) authorEl.textContent = rec.autor;

            const roleEl = card.querySelector('.recommendation-role');
            if (roleEl) roleEl.textContent = rec.cargo;

            const dateEl = card.querySelector('.recommendation-date');
            if (dateEl) dateEl.textContent = rec.fecha;

            const relationEl = card.querySelector('.recommendation-relationship');
            if (relationEl) relationEl.textContent = rec.relacion;

            const messageEl = card.querySelector('.recommendation-message');
            if (messageEl) messageEl.textContent = rec.mensaje;
          });
        };

        // Función para actualizar el enlace de descarga del CV según el idioma
        const applyCvTranslation = () => {
          const cvBtn = document.querySelector('.btn-cv-genesis') as HTMLAnchorElement;
          if (!cvBtn) return;
          const cvUrl = currentLang === 'en' 
            ? cvBtn.getAttribute('data-cv-en') 
            : cvBtn.getAttribute('data-cv-es');
          if (cvUrl) cvBtn.setAttribute('href', cvUrl);
        };

        // Función para actualizar las frases dinámicas de "Diseño para que"
        const updateDynamicPhrases = () => {
          const phrasesStr = t('designwork.phrases');
          const phrases = phrasesStr.split(',');
          (window as any).__i18nPhrases = phrases;
          
          const dynamicText = document.querySelector('.title-part-dynamic') as HTMLElement;
          if (dynamicText) {
            dynamicText.textContent = phrases[0];
          }
        };

        // Función para actualizar mensajes flotantes del proceso
        const updateProcessMessages = () => {
          // Mensajes principales (celdas 3, 6, 9)
          [3, 6, 9].forEach(cell => {
            const msgEl = document.getElementById(`floating-message-${cell}`);
            if (!msgEl) return;
            
            const titleEl = msgEl.querySelector('.floating-message-title');
            if (titleEl) titleEl.textContent = t(`process.msg${cell}.title`);
            
            const listEl = msgEl.querySelector('.floating-message-list');
            if (listEl) {
              const items = t(`process.msg${cell}.items`).split(',');
              listEl.innerHTML = items.map(item => `<li>${item.trim()}</li>`).join('');
            }
          });

          // Mensajes hover (celdas 1, 2, 4, 5, 7, 8)
          [1, 2, 4, 5, 7, 8].forEach(cell => {
            const msgEl = document.getElementById(`floating-message-${cell}`);
            if (!msgEl) return;
            
            const textEl = msgEl.querySelector('.floating-message-text');
            if (textEl) textEl.textContent = t(`process.hover${cell}`);
          });
        };

        // Función principal para aplicar todas las traducciones
        const applyAllTranslations = () => {
          // Actualizar lang del HTML
          const htmlRoot = document.getElementById('html-root');
          if (htmlRoot) htmlRoot.setAttribute('lang', currentLang);

          applyStaticTranslations();
          applyProjectTranslations();
          applyBioTranslation();
          applyRecommendationTranslations();
          applyCvTranslation();
          updateDynamicPhrases();
          updateProcessMessages();
        };

        // Función para actualizar el botón de toggle
        const updateToggleButton = () => {
          const toggleText = document.getElementById('lang-toggle-text');
          const toggleBtn = document.getElementById('lang-toggle');
          if (toggleText) {
            toggleText.textContent = currentLang === 'es' ? 'EN' : 'ES';
          }
          if (toggleBtn) {
            toggleBtn.setAttribute('title', currentLang === 'es' ? 'Switch to English' : 'Cambiar a Español');
          }
        };

        // Función para cambiar idioma
        const switchLanguage = () => {
          currentLang = currentLang === 'es' ? 'en' : 'es';
          localStorage.setItem('portfolio-lang', currentLang);
          applyAllTranslations();
          updateToggleButton();
        };

        // Inicializar cuando el DOM esté listo
        document.addEventListener('DOMContentLoaded', () => {
          const toggleBtn = document.getElementById('lang-toggle');
          if (toggleBtn) {
            toggleBtn.addEventListener('click', switchLanguage);
          }

          // Si el idioma detectado es inglés, aplicar traducciones
          if (currentLang === 'en') {
            applyAllTranslations();
          }
          updateToggleButton();

          // Exponer función de traducción globalmente para que otros scripts la usen
          (window as any).__i18n = {
            t,
            getCurrentLang: () => currentLang,
            translations
          };
        });
      })();
    </script>
  </body>
</html>
