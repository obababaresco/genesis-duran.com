  .process-subtitle {
    font-size: clamp(1rem, 2vw, 1.15rem);
    font-family: var(--font-paragraph);
    color: var(--color-text-white);
    line-height: 1.8;
    font-weight: 400;
    margin: 0;
    opacity: 0.95;
  }

  .process-interactive {
    position: relative;
    min-height: 500px;
  }

  /* Estado inicial */
  .process-start {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: center;
    gap: 1.5rem;
    min-height: 400px;
  }

  .pixelhada-container-initial {
    position: relative;
    width: 100%;
    display: flex;
    justify-content: flex-start;
    align-items: center;
  }

  /* Contenedor wrapper para centrar el hada con respecto al botón */
  .pixelhada-wrapper-initial {
    display: flex;
    justify-content: center;
    align-items: center;
    width: 200px; /* Mismo ancho que el botón */
  }

  .pixelhada-image {
    width: 150px;
    height: auto;
    object-fit: contain;
    transition: transform 0.3s ease;
  }

  .pixelhada-initial {
    display: block;
  }

  .btn-start-process {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.875rem 2rem;
    background-color: var(--color-text-white);
    color: var(--color-text-button-selected);
    border: none;
    border-radius: 8px;
    text-decoration: none;
    font-weight: 600;
    font-size: 0.95rem;
    transition: all 0.3s ease;
    font-family: var(--font-button-selected);
    box-sizing: border-box;
    width: 200px;
    height: 48px;
    cursor: pointer;
  }

  .btn-start-process:hover {
    transform: translateY(-2px);
    box-shadow: 0 5px 15px rgba(255, 255, 255, 0.2);
  }

  /* Estado del camino */
  .process-path {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    position: relative;
    width: 100%;
  }

  .path-layout {
    display: flex;
    align-items: center;
    gap: 2rem;
    position: relative;
    width: 100%;
  }

  .path-container {
    position: relative;
    min-height: 400px;
    padding: 2rem 0;
    width: 100%;
    flex: 1;
    display: flex;
    justify-content: center;
  }

  .btn-nav {
    padding: 0.875rem 2rem;
    border: none;
    border-radius: 8px;
    font-weight: 600;
    font-size: 0.95rem;
    cursor: pointer;
    transition: all 0.3s ease;
    font-family: var(--font-button-selected);
    flex-shrink: 0;
  }

  /* Asegurar que los botones dentro del grid mantengan sus estilos */
  .path-cell-btn.btn-nav {
    padding: 0.875rem 2rem !important;
    border-radius: 8px !important;
    font-weight: 600;
    font-size: 0.95rem;
    cursor: pointer;
    transition: all 0.3s ease;
    font-family: var(--font-button-selected);
  }

  .btn-back.path-cell-btn {
    background-color: var(--color-bg-main) !important;
    color: var(--color-text-white) !important;
    border: 1px solid rgba(255, 255, 255, 0.2) !important;
  }

  .btn-back.path-cell-btn:hover {
    background-color: var(--color-bg-sections) !important;
    border-color: var(--color-primary) !important;
    transform: translateY(-2px);
  }

  .btn-forward.path-cell-btn {
    background-color: var(--color-text-white) !important;
    color: var(--color-text-button-selected) !important;
    border: none !important;
  }

  .btn-forward.path-cell-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 5px 15px rgba(255, 255, 255, 0.2);
  }

  .path-cells {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    grid-template-rows: repeat(3, auto);
    gap: 1.5rem;
    position: relative;
    z-index: 1;
    max-width: 1400px;
    width: 100%;
    margin: 0 auto;
    min-height: 400px;
  }

  /* Flechas de carrusel - ocultas por defecto */
  .carousel-arrows-mobile {
    display: none;
  }

  /* Ajustar gap en pantallas más pequeñas */
  @media (max-width: 1200px) {
    .path-cells {
      gap: 1rem;
      max-width: 100%;
    }
  }
  
  /* Asegurar que el path-container y el botón avanzar estén alineados */
  .path-container {
    flex: 1;
  }
  
  /* Botones dentro del grid - mantener aspecto de botón */
  .path-cell-btn {
    align-self: center;
    justify-self: center;
    width: auto;
    height: auto;
    min-height: auto;
    display: flex;
    align-items: center;
    justify-content: center;
    aspect-ratio: auto;
  }

  /* Botón Volver en la columna 1, fila 1 */
  .btn-back.path-cell-btn {
    grid-column: 1;
    grid-row: 1;
  }

  /* Botón Avanzar en la columna 3, fila 3 */
  .btn-forward.path-cell-btn {
    grid-column: 3;
    grid-row: 3;
  }

  /* Patrón del camino: 5 horizontales arriba, vertical debajo del 5to, luego hacia la izquierda */
  /* Fila 1: 5 rectángulos horizontales (ahora empiezan en columna 2) */
  .path-cell:nth-child(2) { grid-column: 2; grid-row: 1; }
  .path-cell:nth-child(3) { grid-column: 3; grid-row: 1; }
  .path-cell:nth-child(4) { grid-column: 4; grid-row: 1; }
  .path-cell:nth-child(5) { grid-column: 5; grid-row: 1; }
  .path-cell:nth-child(6) { grid-column: 6; grid-row: 1; }
  /* Columna 6: 1 rectángulo vertical debajo del 5to (fila 2) - celda 6 */
  .path-cell:nth-child(7) { grid-column: 6; grid-row: 2; }
  /* Fila 3: rectángulos hacia la izquierda (columna 6, 5 y 4) */
  /* Celda 7 en columna 6, fila 3 */
  .path-cell:nth-child(8) { grid-column: 6; grid-row: 3; }
  /* Celda 8 en columna 5, fila 3 */
  .path-cell:nth-child(9) { grid-column: 5; grid-row: 3; }
  /* Celda 9 en columna 4, fila 3 */
  .path-cell:nth-child(10) { grid-column: 4; grid-row: 3; }

  .path-cell {
    aspect-ratio: 1.5 / 1;
    min-width: 200px;
    min-height: 120px;
    width: 100%;
    background-color: var(--color-bg-main);
    border-radius: 12px;
    border: 1px solid rgba(255, 255, 255, 0.1);
    position: relative;
    display: block;
    opacity: 1;
    cursor: pointer;
    transition: border-color 0.3s ease;
  }

  /* Hover en la celda 1 - mostrar mensaje flotante (manejado por JavaScript) */

  /* Asegurar que los botones no hereden estilos de path-cell */
  .path-cell-btn {
    aspect-ratio: auto !important;
    min-width: auto !important;
    min-height: auto !important;
    width: auto !important;
    background-color: inherit !important;
    border: inherit !important;
    border-radius: inherit !important;
  }

  /* Celda resaltada donde está Pixelhada */
  .path-cell.active-cell {
    background-color: #8a2be2;
    box-shadow: 0 0 20px rgba(138, 43, 226, 0.5);
    border-color: #8a2be2;
  }

  /* Contenedor de Pixelhada para movimiento */
  .pixelhada-wrapper {
    position: absolute;
    top: 0;
    left: 0;
    z-index: 10;
    pointer-events: none;
    opacity: 0;
    transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.3s ease;
  }

  .pixelhada-moving {
    width: 150px;
    height: auto;
    object-fit: contain;
    display: block;
  }

  /* Mensaje flotante */
  .floating-message {
    position: absolute;
    top: -140px;
    left: 125px;
    z-index: 15;
    pointer-events: none;
    display: none; /* Oculto por defecto para que no ocupe espacio */
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  /* Mensaje flotante de la celda 6 - lado izquierdo */
  .floating-message[data-cell="6"] {
    left: auto;
    right: 125px;
  }

  .floating-message-content {
    background-color: var(--color-primary);
    border-radius: 25px 25px 25px 0;
    padding: 1rem;
    position: relative;
    box-shadow: 0 4px 20px rgba(43, 228, 194, 0.3);
    width: fit-content;
    min-width: 180px;
    max-width: 280px;
    display: flex;
    flex-direction: column;
  }

  /* Mensaje de la celda 6 - border radius invertido (esquina inferior derecha sin redondear) */
  .floating-message[data-cell="6"] .floating-message-content {
    border-radius: 25px 25px 0 25px;
  }

  /* Mensaje flotante de la celda 1 - hover (como pensamiento que sale de la celda) */
  .floating-message-hover {
    position: absolute;
    opacity: 0;
    transform: translateX(-50%) translateY(10px) scale(0.8);
    transition: opacity 0.3s ease, transform 0.3s ease;
    z-index: 20;
    pointer-events: none;
    display: none; /* Oculto por defecto para que no ocupe espacio */
  }

  /* Estado visible del mensaje hover - emerge de la celda */
  .floating-message-hover.show {
    display: block !important;
    opacity: 1 !important;
    transform: translateX(-50%) translateY(0) scale(1) !important;
  }

  /* Mensaje simple (sin lista) */
  .floating-message-simple {
    padding: 0.75rem 1.5rem;
    min-width: 250px;
    width: fit-content;
    max-width: 450px;
    border-radius: 25px;
    box-sizing: border-box;
  }

  /* Sin apuntador para el mensaje simple */
  .floating-message-simple::after {
    display: none;
  }

  .floating-message-text {
    font-family: var(--font-paragraph);
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-text-button-selected);
    margin: 0;
    line-height: 1.5;
    text-align: center;
    white-space: normal;
    word-wrap: break-word;
    overflow-wrap: break-word;
    display: block;
    width: 100%;
    box-sizing: border-box;
  }

  /* Apuntador del speech bubble (esquina inferior izquierda) */
  .floating-message-content::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 0;
    border-bottom: 20px solid var(--color-primary);
    border-left: 20px solid transparent;
  }

  /* Apuntador del mensaje de la celda 6 (esquina inferior derecha) */
  .floating-message[data-cell="6"] .floating-message-content::after {
    left: auto;
    right: 0;
    border-left: none;
    border-right: 20px solid transparent;
  }

  .floating-message-title {
    font-family: var(--font-paragraph);
    font-size: 1rem;
    font-weight: 900;
    color: var(--color-text-button-selected);
    margin: 0 0 0.4rem 0;
    line-height: 1.4;
  }

  .floating-message-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .floating-message-list li {
    font-family: var(--font-paragraph);
    font-size: 0.95rem;
    font-weight: 400;
    color: var(--color-text-button-selected);
    line-height: 1.5;
    margin-bottom: 0;
    padding-left: 1.25rem;
    position: relative;
  }

  .floating-message-list li:last-child {
    margin-bottom: 0;
  }

  /* Viñeta personalizada */
  .floating-message-list li::before {
    content: '•';
    position: absolute;
    left: 0;
    color: var(--color-text-button-selected);
    font-weight: 700;
    font-size: 1.2rem;
    line-height: 1.4;
  }


  /* Escritorio mediano - Reducir a 5 columnas */
  @media (max-width: 1300px) {
    .path-cells {
      grid-template-columns: repeat(5, 1fr);
      grid-template-rows: repeat(3, auto);
      gap: 1rem;
    }

    .path-cell {
      min-width: 160px;
      min-height: 100px;
    }

    /* Botón Volver siempre primero */
    .btn-back.path-cell-btn {
      grid-column: 1;
      grid-row: 1;
    }

    /* Botón Avanzar en columna 1, fila 3 */
    .btn-forward.path-cell-btn {
      grid-column: 1;
      grid-row: 3;
    }

    /* Patrón adaptado para 5 columnas */
    /* Fila 1: 3 rectángulos horizontales (empiezan en columna 2) */
    .path-cell:nth-child(2) { grid-column: 2; grid-row: 1; }
    .path-cell:nth-child(3) { grid-column: 3; grid-row: 1; }
    .path-cell:nth-child(4) { grid-column: 4; grid-row: 1; }
    
    /* Celda 5 (data-cell-index="5") en columna 5, fila 2 */
    .path-cell:nth-child(6) { grid-column: 5; grid-row: 2; }
    
    /* Fila 3: rectángulos hacia la izquierda (columnas 5, 4, 3 y 2) */
    /* Celda 6 (data-cell-index="6") en columna 5, fila 3 */
    .path-cell:nth-child(7) { grid-column: 5; grid-row: 3; }
    /* Celda 7 (data-cell-index="7") en columna 4, fila 3 */
    .path-cell:nth-child(8) { grid-column: 4; grid-row: 3; }
    /* Celda 8 (data-cell-index="8") en columna 3, fila 3 */
    .path-cell:nth-child(9) { grid-column: 3; grid-row: 3; }
    /* Celda 9 (data-cell-index="9") en columna 2, fila 3 */
    .path-cell:nth-child(10) { grid-column: 2; grid-row: 3; }
  }

  /* Tablet - Patrón en forma de C */
  @media (max-width: 968px) {
    .path-cells {
      grid-template-columns: repeat(4, 1fr);
      grid-template-rows: repeat(5, auto);
      max-width: 100%;
      gap: 1rem;
    }

    .path-cell {
      min-width: 100px;
      min-height: 80px;
    }

    /* Ocultar mensajes hover en tablet y móvil */
    .floating-message-hover {
      display: none !important;
    }

    /* Mensaje flotante de la celda 3 - lado izquierdo en tablet */
    .floating-message[data-cell="3"] {
      left: auto;
      right: 90px;
    }

    /* Mensaje de la celda 3 - border radius invertido (esquina inferior derecha sin redondear) */
    .floating-message[data-cell="3"] .floating-message-content {
      border-radius: 25px 25px 0 25px;
    }

    /* Apuntador del mensaje de la celda 3 (esquina inferior derecha) */
    .floating-message[data-cell="3"] .floating-message-content::after {
      left: auto;
      right: 0;
      border-left: none;
      border-right: 20px solid transparent;
    }

    /* Patrón C: horizontal arriba, vertical derecha, horizontal abajo */
    /* Botón Volver siempre primero */
    .btn-back.path-cell-btn {
      grid-column: 1;
      grid-row: 1;
    }
    
    /* Fila 1: Horizontal (parte superior de la C) */
    .path-cell:nth-child(2) { grid-column: 2; grid-row: 1; }
    .path-cell:nth-child(3) { grid-column: 3; grid-row: 1; }
    .path-cell:nth-child(4) { grid-column: 4; grid-row: 1; }
    
    /* Columna 4: Vertical (lado derecho de la C) */
    .path-cell:nth-child(5) { grid-column: 4; grid-row: 2; }
    .path-cell:nth-child(6) { grid-column: 4; grid-row: 3; }
    .path-cell:nth-child(7) { grid-column: 4; grid-row: 4; }
    
    /* Fila 5: Horizontal hacia la izquierda (parte inferior de la C) */
    .path-cell:nth-child(8) { grid-column: 4; grid-row: 5; }
    .path-cell:nth-child(9) { grid-column: 3; grid-row: 5; }
    .path-cell:nth-child(10) { grid-column: 2; grid-row: 5; }
    
    /* Botón Avanzar siempre último - columna 1, fila 5 */
    .btn-forward.path-cell-btn {
      grid-column: 1;
      grid-row: 5;
    }
  }

  /* Móvil - Grid más vertical */
  @media (max-width: 640px) {

    .hero-section-genesis {
      padding: 3rem 0 0 0;
    }
    .process-section {
      padding: 4rem 0;
    }

    .process-header {
      margin-bottom: 3rem;
    }

    .process-title {
      font-size: 2rem;
      margin-bottom: 1rem;
    }

    .process-subtitle {
      font-size: 0.95rem;
    }

    .path-layout {
      flex-direction: column;
      align-items: stretch;
      gap: 1.5rem;
    }

    .path-cells {
      grid-template-columns: repeat(2, 1fr);
      grid-template-rows: repeat(3, auto);
      gap: 0.75rem;
      max-width: 100%;
    }

    .path-cell {
      min-width: auto;
      min-height: 60px;
      aspect-ratio: 1.5 / 1;
    }

    .path-cell-btn {
      min-height: 48px;
    }

    .path-container {
      min-height: auto;
      padding: 1rem 0;
    }

    /* Ocultar celdas 1, 2, 4, 5, 7, 8 en móvil */
    .path-cell[data-cell-index="1"],
    .path-cell[data-cell-index="2"],
    .path-cell[data-cell-index="4"],
    .path-cell[data-cell-index="5"],
    .path-cell[data-cell-index="7"],
    .path-cell[data-cell-index="8"] {
      display: none;
    }

    /* Ocultar botones Volver y Avanzar en móvil */
    .btn-back.path-cell-btn,
    .btn-forward.path-cell-btn {
      display: none;
    }

    /* Mostrar flechas de carrusel en móvil */
    .carousel-arrows-mobile {
      display: flex;
    }
    
    /* Celda 3: columna 2, fila 1 */
    .path-cell[data-cell-index="3"] {
      grid-column: 2;
      grid-row: 1;
    }
    
    /* Celda 6: columna 1, fila 2 */
    .path-cell[data-cell-index="6"] {
      grid-column: 1;
      grid-row: 2;
    }
    
    /* Celda 9: columna 2, fila 3 */
    .path-cell[data-cell-index="9"] {
      grid-column: 2;
      grid-row: 3;
    }
    
    /* Botón Avanzar: columna 1, fila 3 */
    .btn-forward.path-cell-btn {
      grid-column: 1;
      grid-row: 3;
    }

    /* Flechas de carrusel para móvil */
    .carousel-arrows-mobile {
      display: flex;
      justify-content: center;
      align-items: center;
      gap: 2rem;
      padding: 1rem 0;
    }

    .carousel-arrow {
      background-color: rgba(255, 255, 255, 0.1);
      border: 1px solid rgba(255, 255, 255, 0.3);
      border-radius: 50%;
      width: 48px;
      height: 48px;
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      transition: all 0.3s ease;
      color: var(--color-text-white);
    }

    .carousel-arrow:hover:not(:disabled) {
      background-color: rgba(255, 255, 255, 0.2);
      border-color: rgba(255, 255, 255, 0.5);
      transform: scale(1.1);
    }

    .carousel-arrow:disabled {
      opacity: 0.3;
      cursor: not-allowed;
    }

    .carousel-arrow svg {
      width: 24px;
      height: 24px;
    }

    /* Mensaje flotante de la celda 3 - lado izquierdo en móvil */
    .floating-message[data-cell="3"] {
      left: auto;
      right: 90px;
    }

    /* Mensaje de la celda 3 - border radius invertido (esquina inferior derecha sin redondear) en móvil */
    .floating-message[data-cell="3"] .floating-message-content {
      border-radius: 25px 25px 0 25px;
    }

    /* Apuntador del mensaje de la celda 3 (esquina inferior derecha) en móvil */
    .floating-message[data-cell="3"] .floating-message-content::after {
      left: auto;
      right: 0;
      border-left: none;
      border-right: 20px solid transparent;
    }

    /* Mensaje flotante de la celda 6 - lado derecho en móvil */
    .floating-message[data-cell="6"] {
      left: 90px;
      right: auto;
    }

    /* Mensaje de la celda 6 - border radius normal (esquina inferior izquierda sin redondear) en móvil */
    .floating-message[data-cell="6"] .floating-message-content {
      border-radius: 25px 25px 25px 0;
    }

    /* Apuntador del mensaje de la celda 6 (esquina inferior izquierda) en móvil */
    .floating-message[data-cell="6"] .floating-message-content::after {
      left: 0;
      right: auto;
      border-left: 20px solid transparent;
      border-right: none;
    }

    /* Mensaje flotante de la celda 9 - lado derecho en móvil */
    .floating-message[data-cell="9"] {
      left: 90px;
      right: auto;
    }

    /* Mensaje de la celda 9 - border radius normal (esquina inferior izquierda sin redondear) en móvil */
    .floating-message[data-cell="9"] .floating-message-content {
      border-radius: 25px 25px 25px 0;
    }

    /* Apuntador del mensaje de la celda 9 (esquina inferior izquierda) en móvil */
    .floating-message[data-cell="9"] .floating-message-content::after {
      left: 0;
      right: auto;
      border-left: 20px solid transparent;
      border-right: none;
    }
  }

  /* Móvil pequeño - 2 columnas */
  @media (max-width: 470px) {
    .path-cells {
      grid-template-columns: repeat(2, 1fr);
      grid-template-rows: auto;
      gap: 0.75rem;
    }

    .path-cell {
      min-height: 60px;
      min-width: 50px;
    }

    .path-cell-btn {
      min-height: 44px;
      padding: 0.75rem 1.5rem !important;
      font-size: 0.875rem;
    }

    /* Botón Volver en columna 1, fila 1 */
    .btn-back.path-cell-btn {
      grid-column: 1;
      grid-row: 1;
    }

    /* Reorganizar patrón para 2 columnas */
    .path-cell:nth-child(2) { grid-column: 2; grid-row: 1; }
    .path-cell:nth-child(3) { grid-column: 1; grid-row: 2; }
    .path-cell:nth-child(4) { grid-column: 2; grid-row: 2; }
    .path-cell:nth-child(5) { grid-column: 1; grid-row: 3; }
    .path-cell:nth-child(6) { grid-column: 2; grid-row: 3; }
    .path-cell:nth-child(7) { grid-column: 1; grid-row: 4; }
    .path-cell:nth-child(8) { grid-column: 2; grid-row: 4; }
    .path-cell:nth-child(9) { grid-column: 1; grid-row: 5; }
    .path-cell:nth-child(10) { grid-column: 2; grid-row: 5; }

    /* Botón Avanzar en columna 2, fila 6 */
    .btn-forward.path-cell-btn {
      grid-column: 2;
      grid-row: 6;
    }

    /* Mensaje flotante de la celda 9 - lado izquierdo en móvil pequeño */
    .floating-message[data-cell="9"] {
      left: auto;
      right: 90px;
    }

    /* Mensaje de la celda 9 - border radius invertido (esquina inferior derecha sin redondear) en móvil pequeño */
    .floating-message[data-cell="9"] .floating-message-content {
      border-radius: 25px 25px 0 25px;
    }

    /* Apuntador del mensaje de la celda 9 (esquina inferior derecha) en móvil pequeño */
    .floating-message[data-cell="9"] .floating-message-content::after {
      left: auto;
      right: 0;
      border-left: none;
      border-right: 20px solid transparent;
    }
    .genesis-photo {
      object-position: center center;
    }
  }

  /* Section Title Styles */
  .section-title {
    font-size: clamp(2rem, 4vw, 3rem);
    font-family: var(--font-heading);
    text-align: center;
    margin-bottom: 3rem;
    color: var(--color-text-white);
    position: relative;
    display: inline-block;
    width: 100%;
  }

  .section-title::after {
    content: '';
    position: absolute;
    bottom: -10px;
    left: 50%;
    transform: translateX(-50%);
    width: 80px;
    height: 3px;
    background: linear-gradient(90deg, transparent, var(--color-primary), transparent);
  }

  /* Recommendations Section */
  .recommendations-section {
    padding: 6rem 0 8rem;
    scroll-margin-top: 100px;
    background: var(--color-bg-main);
  }

  .recommendations-wrapper {
    position: relative;
  }

  .recommendations-wrapper.carousel-active {
    overflow: hidden;
  }

  .recommendations-list {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 2rem;
  }

  .recommendations-list.is-carousel {
    display: flex;
    gap: 1.5rem;
    grid-template-columns: none;
    transition: transform 1.2s ease;
    will-change: transform;
    cursor: grab;
    user-select: none;
  }

  .recommendations-list.is-carousel .recommendation-card {
    flex: 0 0 calc(33.333% - 1rem);
    min-width: 280px;
  }

  .recommendations-list.is-carousel.is-grabbing {
    cursor: grabbing;
  }

  .recommendation-card {
    background: var(--color-bg-sections);
    border-radius: 16px;
    border: 1px solid rgba(255, 255, 255, 0.1);
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    position: relative;
  }

  .recommendation-card::before {
    content: '"';
    position: absolute;
    top: -20px;
    left: 20px;
    font-size: 5rem;
    color: rgba(43, 228, 194, 0.15);
    font-family: var(--font-heading);
  }

  .recommendation-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
  }

  .recommendation-author {
    margin: 0;
    font-size: 1.2rem;
    color: var(--color-text-white);
  }

  .recommendation-role {
    margin: 0.25rem 0 0;
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.7);
  }

  .recommendation-date {
    font-size: 0.85rem;
    color: var(--color-primary);
    font-weight: 600;
  }

  .recommendation-relationship {
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.7);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin: 0;
  }

  .recommendation-message {
    font-size: 1rem;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.9);
    margin: 0;
  }

  /* Responsive para recomendaciones */
  @media (max-width: 968px) {
    .recommendations-list.is-carousel .recommendation-card {
      flex: 0 0 calc(50% - 1rem);
    }
  }

  @media (max-width: 640px) {
    .recommendations-list.is-carousel .recommendation-card {
      flex: 0 0 100%;
    }
  }

  /* Modal de Proyecto */
  .project-modal {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 10000;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.3s ease, visibility 0.3s ease;
  }

  .project-modal.active {
    opacity: 1;
    visibility: visible;
  }

  .modal-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.9);
    backdrop-filter: blur(8px);
  }

  .modal-content {
    position: relative;
    width: 90%;
    max-width: 1200px;
    max-height: 90vh;
    background: var(--color-bg-sections);
    border-radius: 20px;
    border: 1px solid rgba(255, 255, 255, 0.1);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transform: scale(0.9);
    transition: transform 0.3s ease;
    z-index: 1;
  }

  .project-modal.active .modal-content {
    transform: scale(1);
  }

  .modal-close {
    position: absolute;
    top: 1.5rem;
    right: 1.5rem;
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 50%;
    color: var(--color-text-white);
    cursor: pointer;
    transition: all 0.3s ease;
    z-index: 10;
  }

  .modal-close:hover {
    background: var(--color-primary);
    color: var(--color-text-button-selected);
    transform: rotate(90deg);
  }

  .modal-close svg {
    width: 20px;
    height: 20px;
  }

  /* Botones de navegación entre proyectos */
  .modal-nav-btn {
    position: absolute;
    bottom: 1.5rem;
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0, 0, 0, 0.7);
    border: 2px solid rgba(255, 255, 255, 0.3);
    border-radius: 50%;
    color: var(--color-text-white);
    cursor: pointer;
    transition: all 0.3s ease;
    z-index: 15;
    backdrop-filter: blur(10px);
  }

  .modal-nav-btn:hover {
    background: var(--color-primary);
    color: var(--color-text-button-selected);
    border-color: var(--color-primary);
    transform: scale(1.1);
    box-shadow: 0 5px 20px rgba(43, 228, 194, 0.4);
  }

  .modal-nav-btn:active {
    transform: scale(0.95);
  }

  .modal-nav-btn svg {
    width: 24px;
    height: 24px;
  }

  .modal-nav-prev {
    left: 50%;
    transform: translateX(calc(-100% - 0.5rem));
  }

  .modal-nav-prev:hover {
    transform: translateX(calc(-100% - 0.5rem)) scale(1.1);
  }

  .modal-nav-prev:active {
    transform: translateX(calc(-100% - 0.5rem)) scale(0.95);
  }

  .modal-nav-next {
    right: 50%;
    transform: translateX(calc(100% + 0.5rem));
  }

  .modal-nav-next:hover {
    transform: translateX(calc(100% + 0.5rem)) scale(1.1);
  }

  .modal-nav-next:active {
    transform: translateX(calc(100% + 0.5rem)) scale(0.95);
  }

  .modal-body {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    max-height: 90vh;
    overflow: hidden;
  }

  /* Contenedor de Imagen */
  .modal-image-container {
    position: relative;
    width: 100%;
    height: 100%;
    min-height: 500px;
    background: var(--color-bg-main);
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    box-sizing: border-box;
  }

  .image-slider {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .modal-image {
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: center;
    background: var(--color-bg-main);
    display: block;
    transition: opacity 0.3s ease;
  }

  /* Controles del Slider */
  .slider-btn {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0, 0, 0, 0.6);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 50%;
    color: var(--color-text-white);
    cursor: pointer;
    transition: all 0.3s ease;
    z-index: 5;
    backdrop-filter: blur(10px);
  }

  .slider-btn:hover {
    background: var(--color-primary);
    color: var(--color-text-button-selected);
