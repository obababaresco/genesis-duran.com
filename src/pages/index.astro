  .hero-content-genesis {
    display: flex;
    align-items: center;
    padding: 4rem 3rem;
    position: relative;
    z-index: 2;
    grid-column: 1;
    overflow: hidden;
    max-width: 100%;
    box-sizing: border-box;
  }

  .hero-text-genesis {
    width: 100%;
    max-width: 100%;
    box-sizing: border-box;
  }

  .hero-greeting-genesis {
    font-size: clamp(3rem, 8vw, 6rem);
    font-family: var(--font-heading);
    color: var(--color-text-white);
    text-transform: uppercase;
    letter-spacing: 1px;
    font-weight: 700;
    margin: 0;
