  // Sección del proceso interactivo - Movimiento de Pixelhada
  document.addEventListener("DOMContentLoaded", () => {
    const processStart = document.getElementById("process-start") as HTMLElement;
    const processPath = document.getElementById("process-path") as HTMLElement;
    const btnStart = document.getElementById("btn-start-process") as HTMLButtonElement;
    const pathCells = document.querySelector(".path-cells") as HTMLElement;
    const pixelhadaWrapper = document.getElementById("pixelhada-wrapper") as HTMLElement;
    const btnBack = document.getElementById("btn-back") as HTMLButtonElement;
    const btnForward = document.getElementById("btn-forward") as HTMLButtonElement;
    const arrowPrev = document.getElementById("arrow-prev") as HTMLButtonElement;
    const arrowNext = document.getElementById("arrow-next") as HTMLButtonElement;
    const floatingMessages = pixelhadaWrapper.querySelectorAll(".floating-message") as NodeListOf<HTMLElement>;

    if (!processStart || !processPath || !btnStart || !pathCells || !pixelhadaWrapper || !btnBack || !btnForward) return;

    // Posiciones objetivo donde Pixelhada puede estar (celdas 3, 6, 9)
    const targetCells = [3, 6, 9];
    let currentPosition = 0; // Índice en targetCells (0 = celda 3, 1 = celda 6, 2 = celda 9)

    // Función para obtener una celda por su índice
    const getCellByIndex = (index: number): HTMLElement | null => {
      return pathCells.querySelector(`[data-cell-index="${index}"]`) as HTMLElement | null;
    };

    // Función para mostrar/ocultar el mensaje flotante
    const updateFloatingMessage = (cellIndex: number) => {
      if (!pixelhadaWrapper) return;
      
      // Obtener todos los mensajes flotantes (actualizar en cada llamada por si acaso)
      const allMessages = pixelhadaWrapper.querySelectorAll(".floating-message") as NodeListOf<HTMLElement>;
      
      // Ocultar todos los mensajes primero usando display: none para que no ocupen espacio
      allMessages.forEach((message) => {
        if (message) {
          message.style.display = "none";
          message.style.opacity = "0";
        }
      });
      
      // Mostrar el mensaje correspondiente a la celda actual (celdas 3, 6 y 9)
      if (cellIndex === 3 || cellIndex === 6 || cellIndex === 9) {
        const targetMessage = pixelhadaWrapper.querySelector(`.floating-message[data-cell="${cellIndex}"]`) as HTMLElement;
        if (targetMessage) {
          // Esperar 300ms para que primero cargue la imagen y luego el mensaje
          setTimeout(() => {
            // Primero establecer display: block con opacity: 0
            targetMessage.style.display = "block";
            targetMessage.style.opacity = "0";
            // Luego en el siguiente frame, cambiar a opacity: 1 para que la transición funcione
            requestAnimationFrame(() => {
              requestAnimationFrame(() => {
                targetMessage.style.opacity = "1";
              });
            });
          }, 300);
        }
      }
    };

    // Función para mover Pixelhada a una celda específica
    const movePixelhadaToCell = (cellIndex: number) => {
      const cell = getCellByIndex(cellIndex);
      if (!cell || !pixelhadaWrapper) return;

      const pixelhadaImage = pixelhadaWrapper.querySelector("img") as HTMLImageElement;
      if (!pixelhadaImage) return;

      const cellRect = cell.getBoundingClientRect();
      const containerRect = (pathCells.parentElement as HTMLElement).getBoundingClientRect();
      
      // Obtener dimensiones reales de la imagen (considerando el tamaño renderizado)
      const imageWidth = pixelhadaImage.offsetWidth || 120; // Ancho por defecto si no está cargado
      const imageHeight = pixelhadaImage.offsetHeight || 120; // Altura por defecto si no está cargado
      
      // Calcular posición: centrada horizontalmente, pies en la parte inferior de la celda
      // left: centro de la celda menos la mitad del ancho de la imagen
      const left = cellRect.left - containerRect.left + (cellRect.width / 2) - (imageWidth / 2);
      
      // top: parte inferior de la celda menos la altura completa de la imagen (para que los pies toquen el borde)
      const top = cellRect.top - containerRect.top + cellRect.height - imageHeight;
      
      pixelhadaWrapper.style.transform = `translate(${left}px, ${top}px)`;
      pixelhadaWrapper.style.opacity = "1";
      
      // Actualizar posición del mensaje flotante
      updateFloatingMessage(cellIndex);
    };

    // Función para actualizar el resaltado de la celda activa
    const updateActiveCell = (cellIndex: number) => {
      // Remover clase activa de todas las celdas
      const allCells = pathCells.querySelectorAll(".path-cell");
      allCells.forEach((cell) => {
        cell.classList.remove("active-cell");
      });

      // Agregar clase activa a la celda actual
      const activeCell = getCellByIndex(cellIndex);
      if (activeCell) {
        activeCell.classList.add("active-cell");
      }
    };

    // Función para volver a la vista inicial
    const returnToStart = () => {
      // Ocultar el camino iterativo
      processPath.style.display = "none";
      
      // Mostrar la vista inicial
      processStart.style.display = "flex";
      
      // Resetear la posición actual
      currentPosition = 0;
    };

    // Función para actualizar el estado de los botones
    const updateButtons = () => {
      // El botón Volver siempre está habilitado (puede volver al inicio desde celda 3)
      btnBack.disabled = false;
      btnBack.style.opacity = "1";
      btnBack.style.cursor = "pointer";

      // Si estamos en la última posición (celda 8), deshabilitar botón Avanzar
      btnForward.disabled = currentPosition === targetCells.length - 1;
      if (currentPosition === targetCells.length - 1) {
        btnForward.style.opacity = "0.5";
        btnForward.style.cursor = "not-allowed";
      } else {
        btnForward.style.opacity = "1";
        btnForward.style.cursor = "pointer";
      }

      // Actualizar estado de las flechas de carrusel (si existen)
      if (arrowPrev && arrowNext) {
        // La flecha anterior siempre está habilitada (puede volver al inicio desde celda 3)
        arrowPrev.disabled = false;
        
        // Si estamos en la última posición, deshabilitar flecha siguiente
        arrowNext.disabled = currentPosition === targetCells.length - 1;
      }
    };

    // Función para mover a la siguiente posición con iluminación progresiva
    const moveForward = () => {
      if (currentPosition < targetCells.length - 1) {
        const fromCell = targetCells[currentPosition];
        const nextPosition = currentPosition + 1;
        const toCell = targetCells[nextPosition];
        
        // Iluminar celdas progresivamente desde la actual hasta la siguiente
        illuminateCellsProgressively(fromCell, toCell, () => {
          currentPosition = nextPosition;
          movePixelhadaToCell(toCell);
          updateButtons();
        });
      }
    };

    // Función para mover a la posición anterior con desiluminación progresiva
    const moveBack = () => {
      if (currentPosition > 0) {
        const fromCell = targetCells[currentPosition];
        const prevPosition = currentPosition - 1;
        const toCell = targetCells[prevPosition];
        
        // Desiluminar celdas progresivamente desde la actual hasta la anterior
        deilluminateCellsProgressively(fromCell, toCell, () => {
          currentPosition = prevPosition;
          movePixelhadaToCell(toCell);
          updateButtons();
        });
      } else {
        // Si estamos en la primera posición (celda 3), volver al inicio
        returnToStart();
      }
    };

    // Control de scroll del mouse - solo cuando el cursor está sobre el contenedor de celdas
    let scrollTimeout: ReturnType<typeof setTimeout> | null = null;
    let isScrolling = false;
    let isMouseOverCells = false;

    // Detectar cuando el mouse entra o sale del contenedor de celdas
    pathCells.addEventListener("mouseenter", () => {
      isMouseOverCells = true;
    });

    pathCells.addEventListener("mouseleave", () => {
      isMouseOverCells = false;
    });

    const handleWheel = (e: WheelEvent) => {
      if (!isMouseOverCells) return;

      const cellsRect = pathCells.getBoundingClientRect();
      const isInCells = 
        e.clientY >= cellsRect.top && 
        e.clientY <= cellsRect.bottom &&
        e.clientX >= cellsRect.left && 
        e.clientX <= cellsRect.right;

      if (!isInCells) return;

      // Si estamos en la última posición y el usuario hace scroll hacia abajo,
      // permitir el scroll normal para pasar a la siguiente sección
      if (currentPosition === targetCells.length - 1 && e.deltaY > 0) {
        return;
      }

      // Si estamos en la primera posición y el usuario hace scroll hacia arriba,
      // permitir el scroll normal (moveBack ya maneja volver al inicio)
      if (currentPosition === 0 && e.deltaY < 0) {
        return;
      }

      e.preventDefault();

      if (isScrolling) return;

      isScrolling = true;
      
      if (e.deltaY > 0) {
        moveForward();
      } else if (e.deltaY < 0) {
        moveBack();
      }

      if (scrollTimeout) clearTimeout(scrollTimeout);
      scrollTimeout = setTimeout(() => {
        isScrolling = false;
      }, 500);
    };

    // Función para iluminar celdas progresivamente (hacia adelante)
    const illuminateCellsProgressively = (fromCell: number, toCell: number, callback: () => void) => {
      // Determinar las celdas que deben iluminarse en orden
      const cellsToIlluminate: number[] = [];
      for (let i = fromCell; i <= toCell; i++) {
        cellsToIlluminate.push(i);
      }

      let currentCellIndex = 0;

      const illuminateNext = () => {
        if (currentCellIndex < cellsToIlluminate.length) {
          const cellIndex = cellsToIlluminate[currentCellIndex];
          const cell = getCellByIndex(cellIndex);
          
          if (cell) {
            // Agregar clase activa para iluminar
            cell.classList.add("active-cell");
            
            // Si es la última celda, ejecutar callback
            if (currentCellIndex === cellsToIlluminate.length - 1) {
              setTimeout(() => {
                callback();
              }, 200); // Pequeña pausa antes de mover Pixelhada
            } else {
              // Continuar con la siguiente celda
              currentCellIndex++;
              setTimeout(illuminateNext, 400); // Delay de 400ms entre cada iluminación
            }
          }
        }
      };

      // Iniciar la iluminación progresiva
      illuminateNext();
    };

    // Función para desiluminar celdas progresivamente (hacia atrás)
    const deilluminateCellsProgressively = (fromCell: number, toCell: number, callback: () => void) => {
      // Determinar las celdas que deben desiluminarse en orden (de mayor a menor)
      const cellsToDeilluminate: number[] = [];
      for (let i = fromCell; i >= toCell; i--) {
        cellsToDeilluminate.push(i);
      }

      let currentCellIndex = 0;

      const deilluminateNext = () => {
        if (currentCellIndex < cellsToDeilluminate.length) {
          const cellIndex = cellsToDeilluminate[currentCellIndex];
          const cell = getCellByIndex(cellIndex);
          
          if (cell) {
            // Remover clase activa para desiluminar
            cell.classList.remove("active-cell");
            
            // Si es la última celda, ejecutar callback
            if (currentCellIndex === cellsToDeilluminate.length - 1) {
              setTimeout(() => {
                callback();
              }, 200); // Pequeña pausa antes de mover Pixelhada
            } else {
              // Continuar con la siguiente celda
              currentCellIndex++;
              setTimeout(deilluminateNext, 400); // Delay de 400ms entre cada desiluminación
            }
          }
        }
      };

      // Iniciar la desiluminación progresiva
      deilluminateNext();
    };

    // Función para inicializar Pixelhada con animación
    const initPixelhadaWithAnimation = () => {
      const pixelhadaImage = pixelhadaWrapper.querySelector("img") as HTMLImageElement;
      
      // Limpiar todas las clases activas antes de empezar
      const allCells = pathCells.querySelectorAll(".path-cell");
      allCells.forEach((cell) => {
        cell.classList.remove("active-cell");
      });
      
      // Función para mover Pixelhada después de la iluminación inicial
      const movePixelhadaAfterIllumination = () => {
        const initialCellIndex = targetCells[currentPosition]; // celda 3
        
        // Mover Pixelhada a la celda 3 con transición suave
        movePixelhadaToCell(initialCellIndex);
        updateFloatingMessage(initialCellIndex);
        updateButtons();
      };

      // Si la imagen ya está cargada, iniciar animación
      if (pixelhadaImage && pixelhadaImage.complete) {
        requestAnimationFrame(() => {
          requestAnimationFrame(() => {
            // Iluminar celdas progresivamente desde la 1 hasta la 3 y luego mover Pixelhada
            illuminateCellsProgressively(1, 3, movePixelhadaAfterIllumination);
          });
        });
      } else {
        // Esperar a que la imagen se cargue
        if (pixelhadaImage) {
          pixelhadaImage.addEventListener("load", () => {
            requestAnimationFrame(() => {
              requestAnimationFrame(() => {
                // Iluminar celdas progresivamente desde la 1 hasta la 3 y luego mover Pixelhada
                illuminateCellsProgressively(1, 3, movePixelhadaAfterIllumination);
              });
            });
          }, { once: true });
        }
      }
    };

    // Event listener para el botón "Vamos"
    btnStart.addEventListener("click", () => {
      // Ocultar Pixelhada inicialmente
      if (pixelhadaWrapper) {
        pixelhadaWrapper.style.opacity = "0";
      }
      
      // Micro pausa antes de iniciar (0.2-0.3s)
      setTimeout(() => {
        // Ocultar la vista inicial
        processStart.style.display = "none";
        
        // Mostrar el camino iterativo
        processPath.style.display = "flex";
        
        // Inicializar Pixelhada con animación después de que el camino sea visible
        requestAnimationFrame(() => {
          requestAnimationFrame(() => {
            initPixelhadaWithAnimation();
          });
        });
      }, 250);
    });

    // Event listeners para los botones de navegación
    btnForward.addEventListener("click", moveForward);
    btnBack.addEventListener("click", moveBack);

    // Event listeners para las flechas de carrusel (móvil)
    if (arrowPrev) {
      arrowPrev.addEventListener("click", moveBack);
    }
    if (arrowNext) {
      arrowNext.addEventListener("click", moveForward);
    }

    // Event listener para el scroll del mouse
    window.addEventListener("wheel", handleWheel, { passive: false });

    // Mapa de timeouts para cancelar correctamente al re-entrar
    const hoverTimeouts = new Map<number, ReturnType<typeof setTimeout>>();

    // Función genérica para configurar hover de una celda
    const setupCellHover = (cellIndex: number) => {
      const cell = getCellByIndex(cellIndex);
      const floatingMessage = pixelhadaWrapper.querySelector(`.floating-message-hover[data-cell="${cellIndex}"]`) as HTMLElement;
      
      if (!cell || !floatingMessage) {
        return;
      }

      const updateMessagePosition = () => {
        const cellRect = cell.getBoundingClientRect();
        const wrapperRect = pixelhadaWrapper.getBoundingClientRect();
        
        const cellCenterX = cellRect.left + (cellRect.width / 2);
        const left = cellCenterX - wrapperRect.left;
        const top = cellRect.top - wrapperRect.top - 50;
        
        floatingMessage.style.left = `${left}px`;
        floatingMessage.style.top = `${top}px`;
      };

      const hideMessage = () => {
        floatingMessage.classList.remove("show");
        const prevTimeout = hoverTimeouts.get(cellIndex);
        if (prevTimeout) clearTimeout(prevTimeout);

        hoverTimeouts.set(cellIndex, setTimeout(() => {
          if (!floatingMessage.classList.contains("show")) {
            floatingMessage.style.display = "none";
          }
          hoverTimeouts.delete(cellIndex);
        }, 350));
      };

      cell.addEventListener("mouseenter", () => {
        if (window.matchMedia("(max-width: 968px)").matches) return;

        const prevTimeout = hoverTimeouts.get(cellIndex);
        if (prevTimeout) {
          clearTimeout(prevTimeout);
          hoverTimeouts.delete(cellIndex);
        }

        updateMessagePosition();
        floatingMessage.style.display = "block";
        requestAnimationFrame(() => {
          requestAnimationFrame(() => {
            floatingMessage.classList.add("show");
          });
        });
      });

      cell.addEventListener("mouseleave", () => {
        hideMessage();
      });

      // Seguro adicional: ocultar al hacer scroll
      window.addEventListener("scroll", () => {
        if (floatingMessage.classList.contains("show")) {
          hideMessage();
        }
      }, { passive: true });

      window.addEventListener("resize", () => {
        if (floatingMessage.classList.contains("show")) {
          updateMessagePosition();
        }
      });
    };

    // Inicializar el hover de todas las celdas con mensajes (1, 2, 4, 5, 7, 8)
    const setupAllCellHovers = () => {
      const cellsWithHover = [1, 2, 4, 5, 7, 8];
      cellsWithHover.forEach(cellIndex => {
        setupCellHover(cellIndex);
      });
    };

    // Inicializar los hovers después de que el camino sea visible
    requestAnimationFrame(() => {
      requestAnimationFrame(() => {
        setupAllCellHovers();
      });
    });

    // Recalcular posición en resize para mantener Pixelhada y mensaje flotante en su lugar
    let resizeTimeout: ReturnType<typeof setTimeout>;
    window.addEventListener("resize", () => {
      clearTimeout(resizeTimeout);
      resizeTimeout = setTimeout(() => {
        const currentCellIndex = targetCells[currentPosition];
        movePixelhadaToCell(currentCellIndex);
        updateFloatingMessage(currentCellIndex);
      }, 250);
    });
  });

  // Modal de Proyecto con Slider
  document.addEventListener('DOMContentLoaded', () => {
    // Datos de proyectos para el modal
    const proyectosDataEs = JSON.parse(document.getElementById('genesis-proyectos-data')?.textContent || '[]');
    const proyectosDataEn = JSON.parse(document.getElementById('genesis-proyectos-data-en')?.textContent || '[]');
    
    // Función para obtener los datos de proyectos en el idioma actual
    const getProyectosData = () => {
      const i18n = (window as any).__i18n;
      const lang = i18n ? i18n.getCurrentLang() : 'es';
      return lang === 'en' ? proyectosDataEn : proyectosDataEs;
    };
    
    // Referencia dinámica
    let proyectosData = getProyectosData();
    const modal = document.getElementById('project-modal') as HTMLElement;
    const modalOverlay = document.getElementById('modal-overlay') as HTMLElement;
    const modalClose = document.getElementById('modal-close') as HTMLElement;
    const projectButtons = document.querySelectorAll('.project-link[data-project-index]') as NodeListOf<HTMLElement>;
    const modalImage = document.getElementById('modal-image') as HTMLImageElement;
    const modalTitle = document.getElementById('modal-title') as HTMLElement;
    const modalTags = document.getElementById('modal-tags') as HTMLElement;
    const modalDescriptionShort = document.getElementById('modal-description-short') as HTMLElement;
    const modalPais = document.getElementById('modal-pais') as HTMLElement;
    const modalPaisText = document.getElementById('modal-pais-text') as HTMLElement;
    const modalReto = document.getElementById('modal-reto') as HTMLElement;
    const modalRetoText = document.getElementById('modal-reto-text') as HTMLElement;
    const modalSolucion = document.getElementById('modal-solucion') as HTMLElement;
    const modalSolucionText = document.getElementById('modal-solucion-text') as HTMLElement;
    const modalLinkBtn = document.getElementById('modal-link-btn') as HTMLAnchorElement;
    const sliderPrev = document.getElementById('slider-prev') as HTMLElement;
    const sliderNext = document.getElementById('slider-next') as HTMLElement;
    const sliderIndicators = document.getElementById('slider-indicators') as HTMLElement;
    const modalNavPrev = document.getElementById('modal-nav-prev') as HTMLElement;
    const modalNavNext = document.getElementById('modal-nav-next') as HTMLElement;

    if (!modal || !modalOverlay || !modalClose || !modalImage || !modalTitle || !modalTags ||
        !modalDescriptionShort || !modalLinkBtn ||
        !sliderPrev || !sliderNext || !sliderIndicators || !modalNavPrev || !modalNavNext) return;

    let currentImageIndex = 0;
    let currentImages: string[] = [];
    let currentProjectIndex = 0;
    let totalProjects = proyectosData.length;

    // Función para actualizar la imagen mostrada
    const updateImage = () => {
      if (currentImages.length === 0) return;
      modalImage.src = currentImages[currentImageIndex];
      modalImage.alt = modalTitle.textContent || '';
      
      // Actualizar indicadores
      const indicators = sliderIndicators.querySelectorAll('.slider-indicator') as NodeListOf<HTMLElement>;
      indicators.forEach((indicator, index) => {
        indicator.classList.toggle('active', index === currentImageIndex);
      });
    };

    // Función para siguiente imagen
    const nextImage = () => {
      if (currentImages.length <= 1) return;
      currentImageIndex = (currentImageIndex + 1) % currentImages.length;
      updateImage();
    };

    // Función para imagen anterior
    const prevImage = () => {
      if (currentImages.length <= 1) return;
      currentImageIndex = (currentImageIndex - 1 + currentImages.length) % currentImages.length;
      updateImage();
    };

    // Función para ir a una imagen específica
    const goToImage = (index: number) => {
      if (currentImages.length <= 1) return;
      currentImageIndex = index;
      updateImage();
    };

    // Función para inicializar el slider
    const initSlider = (images: string[]) => {
      currentImages = images;
      currentImageIndex = 0;

      // Limpiar indicadores
      sliderIndicators.innerHTML = '';

      if (images.length > 1) {
        // Mostrar controles del slider
        sliderPrev.style.display = 'flex';
        sliderNext.style.display = 'flex';
        sliderIndicators.style.display = 'flex';

        // Crear indicadores
        images.forEach((_, index) => {
          const indicator = document.createElement('button');
          indicator.className = 'slider-indicator';
          if (index === 0) indicator.classList.add('active');
          indicator.setAttribute('aria-label', `Ir a imagen ${index + 1}`);
          indicator.addEventListener('click', () => goToImage(index));
          sliderIndicators.appendChild(indicator);
        });
      } else {
        // Ocultar controles del slider
        sliderPrev.style.display = 'none';
        sliderNext.style.display = 'none';
        sliderIndicators.style.display = 'none';
      }

      updateImage();
    };

    // Función para actualizar los botones de navegación entre proyectos
    const updateProjectNavButtons = () => {
      if (totalProjects <= 1) {
        modalNavPrev.style.display = 'none';
        modalNavNext.style.display = 'none';
      } else {
        modalNavPrev.style.display = 'flex';
        modalNavNext.style.display = 'flex';
      }
    };

    // Función para navegar al siguiente proyecto
    const nextProject = () => {
      if (totalProjects <= 1) return;
      currentProjectIndex = (currentProjectIndex + 1) % totalProjects;
      openModal(currentProjectIndex, false);
    };

    // Función para navegar al proyecto anterior
    const prevProject = () => {
      if (totalProjects <= 1) return;
      currentProjectIndex = (currentProjectIndex - 1 + totalProjects) % totalProjects;
      openModal(currentProjectIndex, false);
    };

    // Función para abrir el modal
    const openModal = (projectIndex: number, updateCurrentIndex = true) => {
      // Refrescar datos en el idioma actual
      proyectosData = getProyectosData();
      totalProjects = proyectosData.length;
      
      if (updateCurrentIndex) {
        currentProjectIndex = projectIndex;
      }
      
      const proyecto = proyectosData[currentProjectIndex];
      if (!proyecto) return;

      // Obtener todas las imágenes: si hay array de imágenes, usarlo; si no, usar solo la imagen única
      const images = proyecto.images && proyecto.images.length > 0 
        ? proyecto.images 
        : [proyecto.image];

      // Inicializar el slider
      initSlider(images);

      // Llenar el modal con la información del proyecto
      modalTitle.textContent = proyecto.title;
      modalDescriptionShort.textContent = proyecto.description;

      // País
      if (proyecto.pais && proyecto.pais.trim() !== '' && modalPais && modalPaisText) {
        modalPaisText.textContent = proyecto.pais;
        modalPais.style.display = 'flex';
      } else if (modalPais) {
        modalPais.style.display = 'none';
      }

      // Reto
      if (proyecto.reto && proyecto.reto.trim() !== '' && modalReto && modalRetoText) {
        modalRetoText.textContent = proyecto.reto;
        modalReto.style.display = 'block';
      } else if (modalReto) {
        modalReto.style.display = 'none';
      }

      // Solución
      if (proyecto.solucion && proyecto.solucion.trim() !== '' && modalSolucion && modalSolucionText) {
        modalSolucionText.textContent = proyecto.solucion;
        modalSolucion.style.display = 'block';
      } else if (modalSolucion) {
        modalSolucion.style.display = 'none';
      }

      // Tags
      modalTags.innerHTML = '';
      proyecto.tags.forEach((tag: string) => {
        const tagSpan = document.createElement('span');
        tagSpan.className = 'modal-tag tag';
        tagSpan.textContent = tag;
        modalTags.appendChild(tagSpan);
      });

      // Link del proyecto
      if (proyecto.link && proyecto.link !== '#' && proyecto.link.trim() !== '') {
        modalLinkBtn.href = proyecto.link;
        modalLinkBtn.style.display = 'inline-flex';
      } else {
        modalLinkBtn.style.display = 'none';
      }

      // Actualizar botones de navegación
      updateProjectNavButtons();

      // Mostrar el modal
      modal.classList.add('active');
      document.body.style.overflow = 'hidden';
    };

    // Función para cerrar el modal
    const closeModal = () => {
      modal.classList.remove('active');
      document.body.style.overflow = '';
    };

    // Event listeners
    projectButtons.forEach((button) => {
      button.addEventListener('click', (e) => {
        e.preventDefault();
        const projectIndex = parseInt(button.getAttribute('data-project-index') || '0');
        openModal(projectIndex);
      });
    });

    modalClose.addEventListener('click', closeModal);
    modalOverlay.addEventListener('click', closeModal);

    // Event listeners para el slider
    sliderNext.addEventListener('click', (e) => {
      e.stopPropagation();
      nextImage();
    });
    sliderPrev.addEventListener('click', (e) => {
      e.stopPropagation();
      prevImage();
    });

    // Event listeners para navegación entre proyectos
    modalNavNext.addEventListener('click', (e) => {
      e.stopPropagation();
      nextProject();
    });
    modalNavPrev.addEventListener('click', (e) => {
      e.stopPropagation();
      prevProject();
    });

    // Navegación con teclado
    document.addEventListener('keydown', (e) => {
      if (!modal.classList.contains('active')) return;

      // Cerrar con ESC
      if (e.key === 'Escape') {
        closeModal();
        return;
      }

      // Navegación entre proyectos con Ctrl/Cmd + flechas
      // O si no hay múltiples imágenes en el slider, usar flechas directamente
      const hasMultipleImages = currentImages.length > 1;
      const isCtrlOrCmd = e.ctrlKey || e.metaKey;

      if (e.key === 'ArrowRight') {
        e.preventDefault();
        if (isCtrlOrCmd || !hasMultipleImages) {
          nextProject();
        } else {
          nextImage();
        }
      } else if (e.key === 'ArrowLeft') {
        e.preventDefault();
        if (isCtrlOrCmd || !hasMultipleImages) {
          prevProject();
        } else {
          prevImage();
        }
      }
    });
  });

  // Carrusel de recomendaciones
  document.addEventListener('DOMContentLoaded', () => {
    const carouselWrappers = document.querySelectorAll('.recommendations-wrapper[data-carousel="true"]');

    carouselWrappers.forEach(wrapperNode => {
      const wrapper = wrapperNode as HTMLElement;
      const list = wrapper.querySelector('.recommendations-list.is-carousel') as HTMLElement | null;
      const cards = wrapper.querySelectorAll('.recommendation-card') as NodeListOf<HTMLElement>;
      if (!list || cards.length <= 3) return;

      let currentIndex = 0;
      let visibleCards = 3;
      let cardWidth = 0;
      let gap = 0;
      let maxIndex = 0;
      let maxTranslate = 0;
      let currentTranslate = 0;
      let intervalId: ReturnType<typeof setInterval> | null = null;
      let isDragging = false;
      let startX = 0;
      let startTranslate = 0;
      let isHovering = false;
      const defaultTransition = 'transform 1.2s ease';

      const getGap = () => {
        const styles = window.getComputedStyle(list);
        const rawGap = styles.columnGap || styles.gap || '0';
        return parseFloat(rawGap) || 0;
      };

      const clamp = (value: number, min: number, max: number) => Math.min(Math.max(value, min), max);

      const applyTranslate = (translate: number, animate = false) => {
        currentTranslate = clamp(translate, 0, maxTranslate);
        list.style.transition = animate ? defaultTransition : 'none';
        list.style.transform = `translateX(-${currentTranslate}px)`;
      };

      const updateMetrics = () => {
        const firstCard = cards[0];
        if (!firstCard) return;
        cardWidth = firstCard.clientWidth;
        gap = getGap();
        const totalCardWidth = cardWidth + gap;
        visibleCards = Math.max(1, Math.round(wrapper.clientWidth / totalCardWidth));
        maxIndex = Math.max(0, cards.length - visibleCards);
        maxTranslate = totalCardWidth * maxIndex;
      };

      const goTo = (index: number, animate = true) => {
        currentIndex = clamp(index, 0, maxIndex);
        const targetTranslate = (cardWidth + gap) * currentIndex;
        applyTranslate(targetTranslate, animate);
      };

      const startAutoSlide = () => {
        if (isHovering) return;
        stopAutoSlide();
        if (maxIndex <= 0) return;
        intervalId = setInterval(() => {
          let nextIndex = currentIndex + 1;
          if (nextIndex > maxIndex) {
            nextIndex = 0;
          }
          goTo(nextIndex, true);
        }, 6000);
      };

      const stopAutoSlide = () => {
        if (intervalId) {
          clearInterval(intervalId);
          intervalId = null;
        }
      };

      const handlePointerDown = (event: PointerEvent) => {
        if (event.pointerType === 'mouse' && event.button !== 0) return;
        event.preventDefault();
        isDragging = true;
        list.setPointerCapture(event.pointerId);
        list.classList.add('is-grabbing');
        startX = event.clientX;
        startTranslate = currentTranslate;
        list.style.transition = 'none';
        stopAutoSlide();
      };

      const handlePointerMove = (event: PointerEvent) => {
        if (!isDragging) return;
        const delta = event.clientX - startX;
        const nextTranslate = startTranslate - delta;
        applyTranslate(nextTranslate, false);
      };

      const endDrag = (event: PointerEvent) => {
        if (!isDragging) return;
        isDragging = false;
        if (list.hasPointerCapture && list.hasPointerCapture(event.pointerId)) {
          list.releasePointerCapture(event.pointerId);
        }
        list.classList.remove('is-grabbing');
        const nearestIndex = Math.round(currentTranslate / (cardWidth + gap));
        goTo(nearestIndex, true);
        if (!isHovering) {
          startAutoSlide();
        }
      };

      list.addEventListener('pointerdown', handlePointerDown);
      list.addEventListener('pointermove', handlePointerMove);
      list.addEventListener('pointerup', endDrag);
      list.addEventListener('pointercancel', endDrag);
      list.addEventListener('pointerleave', (event: PointerEvent) => {
        if (isDragging) {
          endDrag(event);
        }
      });

      wrapper.addEventListener('mouseenter', () => {
        isHovering = true;
        stopAutoSlide();
      });

      wrapper.addEventListener('mouseleave', () => {
        isHovering = false;
        startAutoSlide();
      });

      window.addEventListener('resize', () => {
        updateMetrics();
        goTo(currentIndex, false);
      });

      updateMetrics();
      goTo(0, false);
      startAutoSlide();
    });
  });
</script>

