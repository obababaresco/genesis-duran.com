    font-family: var(--font-heading);
    font-weight: 500;
    line-height: 1.2;
    margin: 0 0 1rem 0;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    letter-spacing: 1px;
  }

  .process-title-line1 {
    color: var(--color-text-white);
    text-transform: uppercase;
    display: block;
  }

  .process-title-line2 {
    color: var(--color-primary);
