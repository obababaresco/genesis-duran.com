---
import GenesisLayout from "../layouts/GenesisLayout.astro";
import genesisData from "../data/genesis-duran.json";
import genesisDataEn from "../data/genesis-duran-en.json";

interface Recommendation {
  autor: string;
  cargo: string;
  relacion?: string;
  fecha?: string;
  mensaje: string;
}

interface Proyecto {
  title: string;
  description: string;
  tags: string[];
  image: string;
  images?: string[];
  link: string;
  category: string;
  pais?: string;
  reto?: string;
  solucion?: string;
}

const resolvePath = (path: string | undefined) => {
  if (!path) return "#";
  if (path.startsWith("http")) return path;
  return path.startsWith("/") ? path : `/${path}`;
};

const genesis = Array.isArray(genesisData) ? genesisData[0] : genesisData;
const genesisEn = Array.isArray(genesisDataEn) ? genesisDataEn[0] : genesisDataEn;
const recomendaciones = genesis?.recomendaciones ?? [];
const recomendacionesEn = genesisEn?.recomendaciones ?? [];
const proyectos = (genesis?.proyectos ?? []) as Proyecto[];
const proyectosEn = (genesisEn?.proyectos ?? []) as Proyecto[];
const hasRecommendations = recomendaciones.length > 0;
const hasRecommendationCarousel = recomendaciones.length > 3;

const whatsappLink = genesis?.whatsapp
  ? `https://wa.me/${genesis.whatsapp.replace(/\D/g, "")}`
  : "#";
---

<GenesisLayout
  title={`Portafolio de ${genesis?.nombre ?? ""} ${genesis?.apellido ?? ""}`}
  whatsapp={whatsappLink}
  linkedin={genesis?.social?.linkedin ?? "#"}
  instagram={genesis?.social?.instagram ?? "#"}
  showRecommendations={hasRecommendations}
>
  <div class="portfolio-container">
    <!-- Sección Hero -->
    <header class="hero-section-genesis" id="acerca-de">
      <div class="hero-banner-genesis">
        <div class="hero-content-genesis">
          <div class="hero-text-genesis">
            <h1 class="hero-greeting-genesis" data-i18n="hero.greeting">HOLA, SOY</h1>
            <h1 class="hero-name-genesis">{genesis?.nombre?.toUpperCase() ?? ""}</h1>
            <p
              class="hero-subtitle-genesis"
              data-bio={genesis?.bio ?? ""}
              set:html={genesis?.bio ? genesis.bio.replace(/\[BR\]/g, "<br />") : ""}
            ></p>
            <div class="hero-buttons-genesis">
              <a href="#contacto" class="btn-contact-genesis" data-i18n="hero.cta">
                Hablemos de ideas
              </a>
              <a
                href={genesis?.cv ? resolvePath(genesis.cv) : "#"}
                class="btn-cv-genesis"
                target="_blank"
                rel="noopener noreferrer"
                download
                data-cv-es={genesis?.cv ? resolvePath(genesis.cv) : "#"}
                data-cv-en={genesisEn?.cv ? resolvePath(genesisEn.cv) : "#"}
              >
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                  <polyline points="7 10 12 15 17 10"></polyline>
                  <line x1="12" y1="15" x2="12" y2="3"></line>
                </svg>
                <span data-i18n="hero.cv">Descargar CV</span>
              </a>
            </div>
          </div>
        </div>
        <div class="hero-image-genesis">
          <img
            src={resolvePath(genesis?.foto)}
            alt={`${genesis?.nombre ?? ""} ${genesis?.apellido ?? ""}`}
            class="genesis-photo"
          />
        </div>
      </div>
    </header>

    <!-- Secci?n Proyectos -->
    <section class="projects-section" id="proyectos">
      <div class="section-container">
        <div class="projects-header">
          <h2 class="projects-title">
            <span class="projects-title-line1" data-i18n="projects.title.line1">EXPERIENCIAS DISEÑADAS</span>
            <span class="projects-title-line2">
              <span data-i18n="projects.title.line2">CON PROPÓSITO.</span>
              <span class="star-mark" aria-hidden="true">&#10022;</span>
            </span>
          </h2>
          <p class="projects-subtitle" data-i18n="projects.subtitle">
            Cada experiencia responde a un contexto distinto.
          </p>
        </div>

        <!-- Filtros de categoría -->
        <div class="projects-filters">
          <button class="filter-btn active" data-category="all" data-i18n="projects.filter.all"
            >Todos los proyectos</button
          >
          <button class="filter-btn" data-category="web" data-i18n="projects.filter.web">Web</button>
          <button class="filter-btn" data-category="social" data-i18n="projects.filter.social"
            >Social Media</button
          >
          <button class="filter-btn" data-category="sales" data-i18n="projects.filter.sales"
            >Sales</button
          >
        </div>

        <!-- Contenedor de proyectos con carrusel -->
        <div class="projects-carousel-wrapper">
          <div class="projects-carousel-container">
            <div class="projects-track">
              {proyectos.map((p, index) => (
                <div class="project-card" data-category={p.category}>
                  <div class="project-image-wrapper">
                    <img
                      src={resolvePath(p.image)}
                      alt={p.title}
                      class="project-image"
                    />
                    <div class="project-overlay">
                      <button class="project-link" type="button" data-project-index={index} data-i18n="projects.view">
                        Ver Proyecto →
                      </button>
                    </div>
                  </div>
                  <div class="project-card-content">
                    <h3 class="project-card-title">{p.title}</h3>
                    <div class="project-tags">
                      {p.tags.map((tag) => (
                        <span class="project-tag tag">{tag}</span>
                      ))}
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Secci?n Texto - Dise?o -->
    <section class="text-section-design" id="diseño">
      <div class="section-container">
        <div class="text-section-content">
          <h2 class="text-section-title">
            <span class="title-line title-line-1" data-i18n="design.line1">NO LLEGUÉ AL DISEÑO</span>
            <span class="title-line title-line-2" data-i18n="design.line2">POR CASUALIDAD.</span>
            <span class="title-line title-line-3" data-i18n="design.line3">LLEGUÉ BUSCANDO</span>
            <span class="title-line title-line-4">
              <span data-i18n="design.line4">RESPUESTAS.</span>
              <img
                src="/images/paleta-de-color.png"
                alt="Paleta de colores"
                class="palette-icon"
              />
            </span>
          </h2>
          <p class="text-section-paragraph" data-i18n="design.paragraph" data-i18n-html="true">
            Siempre me ha interesado entender por qué las personas hacen lo que hacen, qué las frustra, qué las confunde y qué las hace sentir tranquilas cuando interactúan con un producto digital. El diseño se convirtió para mi, en el punto donde pude unir <strong class="highlight-word" data-word="lógica">lógica</strong>, <strong class="highlight-word" data-word="sensibilidad">sensibilidad</strong> y <strong class="highlight-word" data-word="estructura">estructura</strong>.
          </p>
        </div>
      </div>
    </section>

    <!-- Secci?n Texto - Dise?o para que -->
    <section class="text-section-design-work" id="diseño-para-que">
      <div class="section-container">
        <div class="text-section-content">
          <h2 class="text-section-title-work">
            <span class="title-part-static" data-i18n="designwork.static">DISEÑO PARA QUE</span>
            <span class="title-part-dynamic-wrapper">
              <span class="title-part-dynamic" data-phrase="0">FUNCIONE</span>
              <img
                src="/images/modelo-3d.png"
                alt="Modelo 3D"
                class="model-3d-icon"
              />
            </span>
          </h2>
          <p class="text-section-paragraph" data-i18n="designwork.paragraph" data-i18n-html="true">
            Trabajo en UX/UI desde hace más de 6 años, principalmente en <strong>entornos remotos</strong> y multidisciplinarios. Me enfoco en simplificar lo complejo, tomar decisiones con criterio y crear experiencias que se sientan claras, humanas y posibles de usar en la vida real.
          </p>
        </div>
      </div>
    </section>

    <!-- Sección Acompáñame en mi proceso -->
    <section class="process-section" id="proceso">
      <div class="section-container">
        <div class="process-header">
          <h2 class="process-title">
            <span class="process-title-line1" data-i18n="process.title.line1">ACOMPÁÑAME EN</span>
            <span class="process-title-line2" data-i18n="process.title.line2">MI PROCESO</span>
          </h2>
          <p class="process-subtitle" data-i18n="process.subtitle">
            Nada ocurre de golpe. Todo se construye paso a paso.
          </p>
        </div>

        <div class="process-interactive">
          <!-- Vista inicial: Pixelhada y botón Vamos -->
          <div class="process-start" id="process-start">
            <div class="pixelhada-container-initial">
              <div class="pixelhada-wrapper-initial">
                <img 
                  src="/images/pixel-hada.png" 
                  alt="Pixelhada" 
                  class="pixelhada-image pixelhada-initial"
                />
              </div>
            </div>
            <button class="btn-start-process" id="btn-start-process" data-i18n="process.btn.start">
              Vamos
            </button>
          </div>

          <!-- Camino con celdas y Pixelhada (oculto inicialmente) -->
          <div class="process-path" id="process-path" style="display: none;">
            <div class="path-layout">
              <div class="path-container">
                <!-- Contenedor de Pixelhada para movimiento -->
                <div class="pixelhada-wrapper" id="pixelhada-wrapper">
                  <img 
                    src="/images/pixel-hada.png" 
                    alt="Pixelhada" 
                    class="pixelhada-moving"
                    id="pixelhada-image"
                  />
                  <!-- Mensaje flotante para el hada en posición 3 -->
                  <div class="floating-message" id="floating-message-3" data-cell="3">
                    <div class="floating-message-content">
                      <h3 class="floating-message-title" data-i18n="process.msg3.title">Pienso con:</h3>
                      <ul class="floating-message-list">
                        <li>UX Research</li>
                        <li>Arquitectura de información</li>
                        <li>Flujos y journeys</li>
                      </ul>
                    </div>
                  </div>
                  <!-- Mensaje flotante para el hada en posición 6 -->
                  <div class="floating-message" id="floating-message-6" data-cell="6">
                    <div class="floating-message-content">
                      <h3 class="floating-message-title" data-i18n="process.msg6.title">Construyo con:</h3>
                      <ul class="floating-message-list">
                        <li>UI Design</li>
                        <li>Design systems</li>
                        <li>Prototipos funcionales</li>
                      </ul>
                    </div>
                  </div>
                  <!-- Mensaje flotante para el hada en posición 9 -->
                  <div class="floating-message" id="floating-message-9" data-cell="9">
                    <div class="floating-message-content">
                      <h3 class="floating-message-title" data-i18n="process.msg9.title">Me apoyo en:</h3>
                      <ul class="floating-message-list">
                        <li>Figma</li>
                        <li>Photoshop</li>
                        <li>Illustrator</li>
                      </ul>
                    </div>
                  </div>
                  <!-- Mensaje flotante para la celda 1 (hover) -->
                  <div class="floating-message floating-message-hover" id="floating-message-1" data-cell="1">
                    <div class="floating-message-content floating-message-simple">
                      <p class="floating-message-text" data-i18n="process.hover1">Observar también es avanzar</p>
                    </div>
                  </div>
                  <!-- Mensajes flotantes para otras celdas (hover) -->
                  <div class="floating-message floating-message-hover" id="floating-message-2" data-cell="2">
                    <div class="floating-message-content floating-message-simple">
                      <p class="floating-message-text" data-i18n="process.hover2">El proceso importa</p>
                    </div>
                  </div>
                  <div class="floating-message floating-message-hover" id="floating-message-4" data-cell="4">
                    <div class="floating-message-content floating-message-simple">
                      <p class="floating-message-text" data-i18n="process.hover4">Hacer las preguntas correctas cambia todo</p>
                    </div>
                  </div>
                  <div class="floating-message floating-message-hover" id="floating-message-5" data-cell="5">
                    <div class="floating-message-content floating-message-simple">
                      <p class="floating-message-text" data-i18n="process.hover5">Las respuestas no siempre son inmediatas</p>
                    </div>
                  </div>
                  <div class="floating-message floating-message-hover" id="floating-message-7" data-cell="7">
                    <div class="floating-message-content floating-message-simple">
                      <p class="floating-message-text" data-i18n="process.hover7">No todo lo que se diseña se queda</p>
                    </div>
                  </div>
                  <div class="floating-message floating-message-hover" id="floating-message-8" data-cell="8">
                    <div class="floating-message-content floating-message-simple">
                      <p class="floating-message-text" data-i18n="process.hover8">Simplificar es parte del trabajo</p>
                    </div>
                  </div>
                </div>
                <div class="path-cells">
                  <!-- Botón Volver en la celda 1 -->
                  <button class="btn-nav btn-back path-cell-btn" id="btn-back" data-i18n="process.btn.back">
                    Volver
                  </button>
                  <div class="path-cell" data-cell-index="1"></div>
                  <div class="path-cell" data-cell-index="2"></div>
                  <div class="path-cell active-cell" data-cell-index="3"></div>
                  <div class="path-cell" data-cell-index="4"></div>
                  <div class="path-cell" data-cell-index="5"></div>
                  <div class="path-cell" data-cell-index="6"></div>
                  <div class="path-cell" data-cell-index="7"></div>
                  <div class="path-cell" data-cell-index="8"></div>
                  <div class="path-cell" data-cell-index="9"></div>
                  <button class="btn-nav btn-forward btn-white path-cell-btn" id="btn-forward" data-i18n="process.btn.forward">
                    Avanzar
                  </button>
                </div>
              </div>
              <!-- Flechas de navegación para móvil -->
              <div class="carousel-arrows-mobile">
                <button class="carousel-arrow carousel-arrow-prev" id="arrow-prev" aria-label="Anterior">
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M15 18L9 12L15 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </button>
                <button class="carousel-arrow carousel-arrow-next" id="arrow-next" aria-label="Siguiente">
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M9 18L15 12L9 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </button>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    {hasRecommendations && (
      <section class="recommendations-section" id="recomendaciones">
        <div class="section-container">
          <h2 class="section-title" data-i18n="recommendations.title">Recomendaciones</h2>
          <div class={`recommendations-wrapper ${hasRecommendationCarousel ? 'carousel-active' : ''}`} data-carousel={hasRecommendationCarousel ? 'true' : 'false'}>
            <div class={`recommendations-list ${hasRecommendationCarousel ? 'is-carousel' : ''}`}>
              {recomendaciones.map((rec: Recommendation) => (
                <article class="recommendation-card">
                  <div class="recommendation-header">
                    <div>
                      <h3 class="recommendation-author">{rec.autor}</h3>
                      <p class="recommendation-role">{rec.cargo}</p>
                    </div>
                    {rec.fecha && <span class="recommendation-date">{rec.fecha}</span>}
                  </div>
                  {rec.relacion && <p class="recommendation-relationship">{rec.relacion}</p>}
                  <p class="recommendation-message">{rec.mensaje}</p>
                </article>
              ))}
            </div>
          </div>
        </div>
      </section>
    )}
  </div>

  <!-- Modal de Proyecto -->
  <div class="project-modal" id="project-modal" role="dialog" aria-labelledby="modal-title" aria-hidden="true">
    <div class="modal-overlay" id="modal-overlay"></div>
    <div class="modal-content">
      <button class="modal-close" id="modal-close" aria-label="Cerrar modal">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
      
      <!-- Botones de navegación entre proyectos -->
      <button class="modal-nav-btn modal-nav-prev" id="modal-nav-prev" aria-label="Proyecto anterior">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <polyline points="15 18 9 12 15 6"></polyline>
        </svg>
      </button>
      <button class="modal-nav-btn modal-nav-next" id="modal-nav-next" aria-label="Proyecto siguiente">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <polyline points="9 18 15 12 9 6"></polyline>
        </svg>
      </button>
      
      <div class="modal-body">
        <!-- Slider de Imágenes del Proyecto -->
        <div class="modal-image-container" id="modal-image-container">
          <div class="image-slider" id="image-slider">
            <img id="modal-image" class="modal-image" alt="" />
          </div>
          <!-- Controles del slider (solo se muestran si hay múltiples imágenes) -->
          <button class="slider-btn slider-prev" id="slider-prev" aria-label="Imagen anterior" style="display: none;">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="15 18 9 12 15 6"></polyline>
            </svg>
          </button>
          <button class="slider-btn slider-next" id="slider-next" aria-label="Imagen siguiente" style="display: none;">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="9 18 15 12 9 6"></polyline>
            </svg>
          </button>
          <div class="slider-indicators" id="slider-indicators" style="display: none;">
            <!-- Los indicadores se insertarán dinámicamente -->
          </div>
        </div>

        <!-- Contenido del Modal -->
        <div class="modal-info">
          <h2 class="modal-title" id="modal-title"></h2>
          
          <div class="modal-meta">
            <div class="modal-tags" id="modal-tags"></div>
          </div>

          <div class="modal-pais" id="modal-pais" style="display: none;">
            <span class="modal-pais-icon">🌍</span>
            <span class="modal-pais-text" id="modal-pais-text"></span>
          </div>

          <div class="modal-description">
            <p class="modal-description-short" id="modal-description-short"></p>

            <div class="modal-reto" id="modal-reto" style="display: none;">
              <p><strong data-i18n="modal.reto">Reto:</strong> <span id="modal-reto-text"></span></p>
            </div>

            <div class="modal-solucion" id="modal-solucion" style="display: none;">
              <p><strong data-i18n="modal.solucion">Solución:</strong> <span id="modal-solucion-text"></span></p>
            </div>
          </div>

          <div class="modal-actions">
            <a class="modal-link-btn" id="modal-link-btn" target="_blank" rel="noopener noreferrer" style="display: none;">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
                <polyline points="15 3 21 3 21 9"></polyline>
                <line x1="10" y1="14" x2="21" y2="3"></line>
              </svg>
              <span data-i18n="modal.visitsite">Visitar Sitio Web</span>
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</GenesisLayout>

<script id="genesis-proyectos-data" type="application/json" set:html={JSON.stringify(proyectos.map(p => ({
    ...p,
    image: resolvePath(p.image),
    images: p.images ? p.images.map((img: string) => resolvePath(img)) : undefined
  })))}></script>

<script id="genesis-proyectos-data-en" type="application/json" set:html={JSON.stringify(proyectosEn.map(p => ({
    ...p,
    image: resolvePath(p.image),
    images: p.images ? p.images.map((img: string) => resolvePath(img)) : undefined
  })))}></script>

<script id="genesis-bio-data-es" type="text/plain" set:html={genesis?.bio ?? ''}></script>
<script id="genesis-bio-data-en" type="text/plain" set:html={genesisEn?.bio ?? ''}></script>

<script id="genesis-recs-data-es" type="application/json" set:html={JSON.stringify(recomendaciones)}></script>
<script id="genesis-recs-data-en" type="application/json" set:html={JSON.stringify(recomendacionesEn)}></script>

<script>
  // Animación de entrada del hero
  document.addEventListener("DOMContentLoaded", () => {
    const heroSection = document.querySelector(
      ".hero-section-genesis",
    ) as HTMLElement;
    const heroBanner = document.querySelector(
      ".hero-banner-genesis",
    ) as HTMLElement;
    const heroContent = document.querySelector(
      ".hero-content-genesis",
    ) as HTMLElement;
    const heroText = document.querySelector(
      ".hero-text-genesis",
    ) as HTMLElement;
    const heroName = document.querySelector(
      ".hero-name-genesis",
    ) as HTMLElement;
    const heroSubtitle = document.querySelector(
      ".hero-subtitle-genesis",
    ) as HTMLElement;

    if (
      !heroSection ||
      !heroBanner ||
      !heroContent ||
      !heroText ||
      !heroName ||
      !heroSubtitle
    )
      return;

    // Calcular la altura del contenido completo antes de ocultar elementos
    // Primero guardamos el texto original del subtítulo
    const bio =
      heroSubtitle.getAttribute("data-bio") || heroSubtitle.textContent || "";

    // Creamos un elemento temporal con todo el contenido para medir
    const tempDiv = document.createElement("div");
    tempDiv.style.visibility = "hidden";
    tempDiv.style.position = "absolute";
    tempDiv.style.width = heroText.offsetWidth + "px";
    tempDiv.style.padding = window.getComputedStyle(heroText).padding;
    tempDiv.style.fontSize = window.getComputedStyle(heroText).fontSize;
    tempDiv.style.fontFamily = window.getComputedStyle(heroText).fontFamily;
    tempDiv.style.lineHeight = window.getComputedStyle(heroText).lineHeight;

    const tempGreeting = heroName.previousElementSibling?.cloneNode(
      true,
    ) as HTMLElement;
    const tempName = heroName.cloneNode(true) as HTMLElement;
    const tempSubtitle = heroSubtitle.cloneNode(true) as HTMLElement;

    if (tempGreeting) tempDiv.appendChild(tempGreeting);
    tempDiv.appendChild(tempName);
    if (tempSubtitle) {
      // Reemplazar el marcador [BR] con un <br> real para calcular la altura correcta
      const bioWithBr = bio.replace(/\[BR\]/g, "<br>");
      tempSubtitle.innerHTML = bioWithBr;
      // Asegurar que el tempSubtitle tenga los mismos estilos que el original
      tempSubtitle.style.width = window.getComputedStyle(heroSubtitle).width;
      tempSubtitle.style.fontSize =
        window.getComputedStyle(heroSubtitle).fontSize;
      tempSubtitle.style.lineHeight =
        window.getComputedStyle(heroSubtitle).lineHeight;
      tempSubtitle.style.fontFamily =
        window.getComputedStyle(heroSubtitle).fontFamily;
      tempSubtitle.style.marginBottom =
        window.getComputedStyle(heroSubtitle).marginBottom;
      tempDiv.appendChild(tempSubtitle);
    }

    document.body.appendChild(tempDiv);
    const calculatedHeight = tempDiv.offsetHeight;
    const subtitleHeight = tempSubtitle ? tempSubtitle.offsetHeight : 0;
    document.body.removeChild(tempDiv);

    // Establecer la altura mínima calculada en el contenedor de texto
    // Usar la altura real calculada del subtítulo completo
    heroText.style.minHeight = calculatedHeight + "px";
    heroSubtitle.style.minHeight = subtitleHeight + "px";

    // El nombre ya está oculto inicialmente por CSS, solo limpiamos el subtítulo
    heroSubtitle.style.opacity = "0";
    heroSubtitle.textContent = "";

    // Nombre aparece a los 1 segundo (1000ms) desde la izquierda
    // La transición ya está definida en CSS, solo cambiamos los valores
    setTimeout(() => {
      heroName.style.opacity = "1";
      heroName.style.transform = "translateX(0)";
    }, 1000);

    // Subtítulo aparece letra por letra después del nombre
    // Primero hacemos visible el contenedor del subtítulo
    heroSubtitle.style.opacity = "1";

    // Pre-procesar el bio en tokens (palabras, espacios y [BR])
    // para poder agrupar letras por palabra y evitar cortes de palabra en pantallas pequeñas
    const tokens: { type: "word" | "space" | "br"; text: string }[] = [];
    let i = 0;
    while (i < bio.length) {
      if (bio.substring(i, i + 4) === "[BR]") {
        tokens.push({ type: "br", text: "[BR]" });
        i += 4;
      } else if (bio[i] === " ") {
        tokens.push({ type: "space", text: " " });
        i++;
      } else {
        let word = "";
        while (i < bio.length && bio[i] !== " " && bio.substring(i, i + 4) !== "[BR]") {
          word += bio[i];
          i++;
        }
        tokens.push({ type: "word", text: word });
      }
    }

    // Construir todos los elementos del DOM de una vez, pero con opacidad 0
    // Cada palabra se envuelve en un inline-block para que no se corte entre líneas
    const allCharSpans: HTMLSpanElement[] = [];
    const delaysPerChar: number[] = [];

    tokens.forEach((token) => {
      if (token.type === "br") {
        const br = document.createElement("br");
        heroSubtitle.appendChild(br);
        // Agregar un "delay slot" para la pausa del BR
        allCharSpans.push(null as any); // placeholder
        delaysPerChar.push(100);
      } else if (token.type === "space") {
        const spaceSpan = document.createElement("span");
        spaceSpan.textContent = "\u00A0";
        spaceSpan.style.opacity = "0";
        spaceSpan.style.display = "inline";
        heroSubtitle.appendChild(spaceSpan);
        allCharSpans.push(spaceSpan);
        delaysPerChar.push(100); // Pausa más larga en espacios
      } else {
        // Palabra: envolver en un contenedor inline-block para evitar cortes
        const wordWrapper = document.createElement("span");
        wordWrapper.style.display = "inline-block";
        wordWrapper.style.whiteSpace = "nowrap";

        for (const char of token.text) {
          const charSpan = document.createElement("span");
          charSpan.textContent = char;
          charSpan.style.opacity = "0";
          charSpan.style.display = "inline";
          wordWrapper.appendChild(charSpan);
          allCharSpans.push(charSpan);
          delaysPerChar.push(50); // Velocidad normal entre letras
        }

        heroSubtitle.appendChild(wordWrapper);
      }
    });

    // Animar mostrando cada carácter secuencialmente
    let currentCharIndex = 0;
    const showNextChar = () => {
      if (currentCharIndex < allCharSpans.length) {
        const span = allCharSpans[currentCharIndex];
        const delay = delaysPerChar[currentCharIndex];

        if (span) {
          // Es un carácter real, animarlo
          setTimeout(() => {
            span.style.transition = "opacity 0.2s ease-in-out";
            span.style.opacity = "1";
          }, 10);
        }
        // Si span es null, es un placeholder de [BR], solo avanzamos con delay

        currentCharIndex++;
        setTimeout(showNextChar, delay);
      }
    };

    // Iniciar animación del subtítulo después del nombre (1 segundos + un poco más)
    setTimeout(() => {
      showNextChar();
    }, 1900);
  });

  // Carrusel y filtrado de proyectos
  document.addEventListener("DOMContentLoaded", () => {
    const filterButtons = document.querySelectorAll(".filter-btn");
    const projectCards = document.querySelectorAll(".project-card");
    const projectsTrack = document.querySelector(
      ".projects-track",
    ) as HTMLElement;

    if (!filterButtons.length || !projectCards.length || !projectsTrack) return;

    let currentIndex = 0;
    let visibleCards: HTMLElement[] = [];

    // Función para obtener las tarjetas visibles según el filtro
    const getVisibleCards = (category: string): HTMLElement[] => {
      return Array.from(projectCards)
        .filter((card) => {
          const cardCategory = card.getAttribute("data-category");
          return category === "all" || cardCategory === category;
        })
        .map((card) => card as HTMLElement);
    };

    // Variables para el arrastre
    let isDragging = false;
    let startX = 0;
    let currentTranslate = 0;
    let prevTranslate = 0;
    let animationID = 0;

    // Función para actualizar el carrusel
    const updateCarousel = (useTransition = true) => {
      if (visibleCards.length === 0) return;

      // Asegurar que el índice esté dentro del rango
      if (currentIndex >= visibleCards.length) {
        currentIndex = visibleCards.length - 1;
      }
      if (currentIndex < 0) {
        currentIndex = 0;
      }

      // Calcular el ancho de la tarjeta y el gap
      const cardWidth = visibleCards[0]?.offsetWidth || 320;
      const gap = window.innerWidth <= 640 ? 24 : 32; // 1.5rem o 2rem
      const translateX = -(currentIndex * (cardWidth + gap)) + currentTranslate;

      if (useTransition) {
        projectsTrack.style.transition = "transform 0.6s cubic-bezier(0.4, 0, 0.2, 1)";
      } else {
        projectsTrack.style.transition = "none";
      }
      projectsTrack.style.transform = `translateX(${translateX}px)`;

      // Todas las cards igual de visibles y mismo tamaño
      visibleCards.forEach((card) => {
        card.style.opacity = "1";
        card.style.transform = "scale(1)";
        card.style.zIndex = "1";
      });
    };

    // Función para obtener la posición del evento
    const getPositionX = (event: MouseEvent | TouchEvent): number => {
      return event.type.includes("mouse") 
        ? (event as MouseEvent).clientX 
        : (event as TouchEvent).touches[0].clientX;
    };

    // Función para iniciar el arrastre
    const startDrag = (event: MouseEvent | TouchEvent) => {
      startX = getPositionX(event);
      isDragging = true;
      prevTranslate = currentTranslate;
      
      const carouselContainer = document.querySelector(
        ".projects-carousel-container"
      ) as HTMLElement;
      if (carouselContainer) {
        carouselContainer.style.cursor = "grabbing";
      }
      cancelAnimationFrame(animationID);
    };

    // Función para mover durante el arrastre
    const drag = (event: MouseEvent | TouchEvent) => {
      if (!isDragging) return;
      
      event.preventDefault();
      const currentPosition = getPositionX(event);
      currentTranslate = prevTranslate + currentPosition - startX;
      
      // Limitar el arrastre en los bordes para evitar efecto rebote
      if (currentIndex === 0 && currentTranslate > 0) {
        currentTranslate = 0;
      }
      if (currentIndex >= visibleCards.length - 1 && currentTranslate < 0) {
        currentTranslate = 0;
      }
      
      updateCarousel(false);
    };

    // Función para finalizar el arrastre
    const endDrag = () => {
      if (!isDragging) return;
      
      isDragging = false;
      const carouselContainer = document.querySelector(
        ".projects-carousel-container"
      ) as HTMLElement;
      if (carouselContainer) {
        carouselContainer.style.cursor = "grab";
      }
      
      const cardWidth = visibleCards[0]?.offsetWidth || 320;
      const gap = window.innerWidth <= 640 ? 24 : 32;
      const cardWidthWithGap = cardWidth + gap;
      
      // Determinar si debe moverse a la siguiente/anterior tarjeta
      const movedBy = currentTranslate;
      const threshold = cardWidthWithGap * 0.3; // 30% del ancho de la tarjeta
      
      if (Math.abs(movedBy) > threshold) {
        if (movedBy > 0 && currentIndex > 0) {
          currentIndex--;
        } else if (movedBy < 0 && currentIndex < visibleCards.length - 1) {
          currentIndex++;
        }
      }
      
      // Resetear el desplazamiento y actualizar
      currentTranslate = 0;
      prevTranslate = 0;
      updateCarousel(true);
    };

    // Función para agregar event listeners de arrastre al contenedor
    const addDragListeners = () => {
      const carouselContainer = document.querySelector(
        ".projects-carousel-container"
      ) as HTMLElement;
      
      if (!carouselContainer) return;

      // Remover listeners anteriores si existen
      const existingStart = (carouselContainer as any).__dragStart;
      const existingDrag = (carouselContainer as any).__dragMove;
      const existingEnd = (carouselContainer as any).__dragEnd;
      
      if (existingStart) {
        carouselContainer.removeEventListener("mousedown", existingStart);
        carouselContainer.removeEventListener("touchstart", existingStart);
      }
      if (existingDrag) {
        carouselContainer.removeEventListener("mousemove", existingDrag);
        carouselContainer.removeEventListener("touchmove", existingDrag);
      }
      if (existingEnd) {
        carouselContainer.removeEventListener("mouseup", existingEnd);
        carouselContainer.removeEventListener("mouseleave", existingEnd);
        carouselContainer.removeEventListener("touchend", existingEnd);
      }

      // Mouse events
      carouselContainer.addEventListener("mousedown", startDrag);
      carouselContainer.addEventListener("mousemove", drag);
      carouselContainer.addEventListener("mouseup", endDrag);
      carouselContainer.addEventListener("mouseleave", endDrag);
      
      // Touch events para móviles
      carouselContainer.addEventListener("touchstart", startDrag, { passive: false });
      carouselContainer.addEventListener("touchmove", drag, { passive: false });
      carouselContainer.addEventListener("touchend", endDrag);
      
      // Guardar referencias
      (carouselContainer as any).__dragStart = startDrag;
      (carouselContainer as any).__dragMove = drag;
      (carouselContainer as any).__dragEnd = endDrag;
      
      // Cursor grab
      carouselContainer.style.cursor = "grab";
    };

    // Función para reorganizar tarjetas según el filtro
    const reorganizeCards = (category: string) => {
      visibleCards = getVisibleCards(category);

      // Reorganizar visualmente las tarjetas en el DOM
      projectCards.forEach((card) => {
        const cardElement = card as HTMLElement;
        const cardCategory = card.getAttribute("data-category");
        const shouldShow = category === "all" || cardCategory === category;

        if (shouldShow) {
          cardElement.style.display = "block";
          cardElement.style.opacity = "1";
          cardElement.style.transform = "translateX(0) scale(1)";
        } else {
          cardElement.style.display = "none";
        }
      });

      // Reorganizar el orden en el DOM para que las visibles estén primero
      visibleCards.forEach((card, index) => {
        projectsTrack.appendChild(card);
        card.style.order = index.toString();
      });

      // Resetear índice y actualizar carrusel después de que el DOM se actualice
      currentIndex = 0;
      
      // Esperar a que el navegador recalcule los tamaños
      requestAnimationFrame(() => {
        setTimeout(() => {
          // Resetear variables de arrastre
          currentTranslate = 0;
          prevTranslate = 0;
          isDragging = false;
          
          updateCarousel();
          // Actualizar visibleCards y agregar listeners
          visibleCards = getVisibleCards(category);
          addDragListeners();
        }, 100);
      });
    };

    // Event listeners para filtros
    filterButtons.forEach((button) => {
      button.addEventListener("click", () => {
        const category = button.getAttribute("data-category") || "all";

        // Actualizar botones activos
        filterButtons.forEach((btn) => btn.classList.remove("active"));
        button.classList.add("active");

        // Reorganizar tarjetas
        reorganizeCards(category);
      });
    });

    // Inicializar con "Todos los proyectos"
    reorganizeCards("all");
    
    // Agregar listeners iniciales
    addDragListeners();
  });

  // Efecto de iluminación suave en scroll para palabras destacadas
  document.addEventListener("DOMContentLoaded", () => {
    const textSection = document.querySelector(
      ".text-section-design",
    ) as HTMLElement;
    const highlightWords = document.querySelectorAll(
      ".highlight-word",
    ) as NodeListOf<HTMLElement>;

    if (!textSection || !highlightWords.length) return;

    const words = Array.from(highlightWords);
    const wordOrder = ["lógica", "sensibilidad", "estructura"];
    
    // Ordenar las palabras según el orden especificado
    const orderedWords = wordOrder.map((word) =>
      words.find((w) => w.getAttribute("data-word") === word),
    ).filter(Boolean) as HTMLElement[];

    // Función para calcular el progreso del scroll
    const updateHighlight = () => {
      const rect = textSection.getBoundingClientRect();
      const windowHeight = window.innerHeight;

      // Calcular cuando la sección está visible
      const sectionTop = rect.top;
      const sectionBottom = rect.bottom;

      // La sección está visible cuando está en la ventana
      if (sectionTop < windowHeight && sectionBottom > 0) {
        // Calcular el progreso del scroll dentro de la sección
        // Empezamos a iluminar cuando la sección entra en el tercio superior de la ventana
        const startPoint = windowHeight * 0.6;
        const endPoint = windowHeight * 0.1;
        const totalRange = startPoint - endPoint;
        
        // Progreso de 0 a 1 a medida que scrolleamos
        const scrollProgress = Math.max(
          0,
          Math.min(1, (startPoint - sectionTop) / totalRange),
        );

        // Iluminar palabras una a una según el progreso
        const wordsCount = orderedWords.length;
        const progressPerWord = 1 / wordsCount;

        orderedWords.forEach((word, index) => {
          const wordStart = index * progressPerWord;
          const wordEnd = (index + 1) * progressPerWord;
          
          // Si el progreso está en el rango de esta palabra
          if (scrollProgress >= wordStart) {
            // Calcular la intensidad de iluminación para esta palabra
            const wordProgress = Math.min(
              1,
              (scrollProgress - wordStart) / progressPerWord,
            );
            
            // Aplicar iluminación suave - sin animación llamativa
            // La intensidad va de 0 a 1 suavemente
            const intensity = wordProgress;
            const glowIntensity = intensity * 15; // Brillo máximo de 15px
            const glowOpacity = intensity * 0.5; // Opacidad máxima de 0.5
            
            // Color que va del blanco al color primario suavemente
            const colorMix = intensity;
            const r = Math.round(255 * (1 - colorMix) + 43 * colorMix);
            const g = Math.round(255 * (1 - colorMix) + 228 * colorMix);
            const b = Math.round(255 * (1 - colorMix) + 194 * colorMix);
            
            word.style.textShadow = `0 0 ${glowIntensity}px rgba(43, 228, 194, ${glowOpacity})`;
            word.style.color = `rgb(${r}, ${g}, ${b})`;
            word.classList.add("highlighted");
          } else {
            // Restablecer estado inicial
            word.style.textShadow = "none";
            word.style.color = "";
            word.classList.remove("highlighted");
          }
        });
      } else {
        // Si la sección no está visible, resetear
        orderedWords.forEach((word) => {
          word.style.textShadow = "none";
          word.style.color = "";
          word.classList.remove("highlighted");
        });
      }
    };

    // Throttle para mejorar rendimiento
    let ticking = false;
    const onScroll = () => {
      if (!ticking) {
        window.requestAnimationFrame(() => {
          updateHighlight();
          ticking = false;
        });
        ticking = true;
      }
    };

    window.addEventListener("scroll", onScroll);
    // Ejecutar una vez al cargar
    updateHighlight();
  });

  // Cambio automático de frase en título "Diseño para que"
  document.addEventListener("DOMContentLoaded", () => {
    const dynamicText = document.querySelector(
      ".title-part-dynamic",
